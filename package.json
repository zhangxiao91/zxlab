{
  "name": "zxlab",
  "type": "module",
  "version": "0.0.1",
  "workspaces": [
    "apps/stonks",
    "apps/zxtoolkit",
    "apps/signal-worker",
    "packages/signal-schema"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:stonks && astro build && node scripts/check-internal-links.mjs",
    "generate:yuragi-home": "node scripts/generate-yuragi-home.mjs",
    "build:zxtoolkit": "npm run build --workspace zxtoolkit",
    "build:stonks": "npm run build --workspace stonks-wip",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check --tsconfig tsconfig.digital-starter.json --minimumSeverity error",
    "typecheck:ai": "tsc --noEmit --project tsconfig.ai.json --pretty false",
    "notes:publish:technical": "node --experimental-strip-types scripts/publish-obsidian-notes.ts technical",
    "notes:publish:journal": "node --experimental-strip-types scripts/publish-obsidian-notes.ts journal",
    "notes:covers:technical": "node --experimental-strip-types scripts/generate-note-covers.ts technical",
    "notes:covers:journal": "node --experimental-strip-types scripts/generate-note-covers.ts journal",
    "test:notes-publisher": "node --test --experimental-strip-types scripts/obsidian-publisher.test.ts",
    "test:ai": "node --test --experimental-strip-types tests/ai-gateway.test.ts",
    "test:risk": "tsx --test tests/risk-engine.test.ts tests/risk-review-api.test.ts tests/risk-holdings-parser.test.ts tests/risk-dogfooding.test.ts tests/risk-market.test.ts tests/risk-portfolio-history.test.ts",
    "verify:status": "node --experimental-strip-types scripts/verify-status-usage.ts",
    "verify:strudel": "node --experimental-strip-types scripts/verify-strudel.ts",
    "check:links": "node scripts/check-internal-links.mjs",
    "check:digital-starter": "node --experimental-strip-types scripts/check-digital-starter.mjs",
    "test:collector": "npm --prefix services/codex-usage-collector test"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@yuragi-labs/react": "0.1.0",
    "astro": "^7.0.5",
    "echarts": "^6.1.0",
    "gsap": "^3.15.0",
    "jose": "^6.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@yuragi-labs/compiler": "0.1.0",
    "typescript": "^6.0.3"
  }
}
