{
  "name": "zxlab",
  "type": "module",
  "version": "0.0.1",
  "workspaces": [
    "apps/stonks",
    "apps/zxtoolkit"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:stonks && astro build && node scripts/check-internal-links.mjs",
    "build:zxtoolkit": "npm run build --workspace zxtoolkit",
    "build:stonks": "npm run build --workspace stonks-wip",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check --tsconfig tsconfig.digital-starter.json --minimumSeverity error",
    "notes:publish:technical": "node --experimental-strip-types scripts/publish-obsidian-notes.ts technical",
    "notes:publish:journal": "node --experimental-strip-types scripts/publish-obsidian-notes.ts journal",
    "test:notes-publisher": "node --test --experimental-strip-types scripts/obsidian-publisher.test.ts",
    "verify:status": "node --experimental-strip-types scripts/verify-status-usage.ts",
    "verify:strudel": "node --experimental-strip-types scripts/verify-strudel.ts",
    "check:links": "node scripts/check-internal-links.mjs",
    "test:collector": "npm --prefix services/codex-usage-collector test"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.5",
    "gsap": "^3.15.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3"
  }
}
