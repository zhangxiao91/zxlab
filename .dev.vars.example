# Copy to .dev.vars for Cloudflare Pages local development. Never commit real values.
ENVIRONMENT=development

PROVIDER1_BASE_URL=https://provider-1.example/v1
PROVIDER1_API_KEY=
PROVIDER1_GPT56_MODEL=
PROVIDER1_GPT55_MODEL=

PROVIDER2_BASE_URL=https://provider-2.example/v1
PROVIDER2_API_KEY=
PROVIDER2_GPT55_MODEL=

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_V4_PRO_MODEL=

# Optional in development. Set this in production unless a supported
# AI_RATE_LIMITER binding and application authentication are present.
AI_GATEWAY_ACCESS_TOKEN=
AI_GATEWAY_ALLOWED_ORIGINS=http://localhost:4321

# Cloudflare Access application protecting /lab/risk and /api/risk/review.
RISK_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
RISK_ACCESS_AUD=
