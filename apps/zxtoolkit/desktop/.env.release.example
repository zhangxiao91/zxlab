# 从 Apple Developer / App Store Connect 获取；不要提交真实值。
APPLE_SIGNING_IDENTITY="Developer ID Application: Example Name (TEAMID)"
APPLE_TEAM_ID="TEAMID"

# 推荐：App Store Connect API Key notarization。
APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"
APPLE_API_KEY_PATH="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"

# 备选：Apple ID + app-specific password。
# APPLE_ID="developer@example.com"
# APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
