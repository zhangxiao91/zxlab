{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zxdrop",
  "version": "0.1.0",
  "identifier": "com.zxlab.zxdrop",
  "build": {
    "beforeDevCommand": "npm run dev:desktop:web",
    "devUrl": "http://localhost:4174",
    "beforeBuildCommand": "npm run build:desktop:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "zxdrop",
        "width": 360,
        "height": 580,
        "minWidth": 340,
        "minHeight": 540,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "transparent": false,
        "shadow": true,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8787 https://*.workers.dev; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
