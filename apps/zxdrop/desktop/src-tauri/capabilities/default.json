{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Minimal permissions for the zxdrop menu bar window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-read-text",
    "store:default",
    "opener:allow-open-url",
    "autostart:default"
  ]
}
