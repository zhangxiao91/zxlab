{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "zx-signal",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "zx-signal",
      "database_id": "2968cf60-f38f-4488-8a83-2479d4ba3ee2",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "ZX_SIGNAL_LLM_API_URL": "https://beta.zxlab.pages.dev/api/ai/generate",
    "ZX_SIGNAL_LLM_LABEL": "zxlab-project-gateway",
    "ZX_SIGNAL_ALLOWED_ORIGINS": "https://zx-dx.xyz,http://localhost:4321",
    "ZX_SIGNAL_ACCESS_ENABLED": "false"
  },
  "secrets": {
    "required": ["ZX_SIGNAL_LLM_API_TOKEN", "ZX_SIGNAL_WRITE_TOKEN"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
