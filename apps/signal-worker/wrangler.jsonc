{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "zx-signal",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "zx-signal",
      "database_id": "2968cf60-f38f-4488-8a83-2479d4ba3ee2",
      "migrations_dir": "migrations"
    }
  ],
  "triggers": {
    "crons": ["30 23 * * *"]
  },
  "routes": [
    { "pattern": "signal-api.zx-dx.xyz", "custom_domain": true }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "ZX_SIGNAL_LLM_API_URL": "https://beta.zxlab.pages.dev/api/ai/stream",
    "ZX_SIGNAL_LLM_LABEL": "zxlab-project-gateway",
    "ZX_SIGNAL_USER_AGENT": "zxlab-signal/0.2 (+https://zx-dx.xyz)",
    "ZX_SIGNAL_ALLOWED_ORIGINS": "https://zx-dx.xyz,https://beta.zxlab.pages.dev,http://localhost:4321",
    "ZX_SIGNAL_ACCESS_ENABLED": "true",
    "ZX_SIGNAL_SCHEDULE_ENABLED": "true",
    "ZX_SIGNAL_MARKET_NEWS_URL": "https://zxlab-risk-market.zhangxiao9118.workers.dev/api/market/news",
    "CF_ACCESS_TEAM_DOMAIN": "https://zxdx1.cloudflareaccess.com",
    "CF_ACCESS_AUD": "7559429b1da91fe218c27db2cdee8c70cec97195d9b86a0effea1b1916f84e64"
  },
  "secrets": {
    "required": ["ZX_SIGNAL_LLM_API_TOKEN", "ZX_SIGNAL_WRITE_TOKEN"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
