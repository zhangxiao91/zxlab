{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "zx-signal-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "zx-signal-test",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "ZX_SIGNAL_EDITOR_MODEL": "test-model",
    "ZX_SIGNAL_REPLY_MODEL": "test-model",
    "ZX_SIGNAL_MEMORY_MODEL": "test-model",
    "ZX_SIGNAL_GATEWAY_ID": "test-gateway",
    "ZX_SIGNAL_ALLOWED_ORIGINS": "http://localhost:4321",
    "ZX_SIGNAL_ACCESS_ENABLED": "false",
    "ZX_SIGNAL_WRITE_TOKEN": "test-only-not-a-secret"
  }
}
