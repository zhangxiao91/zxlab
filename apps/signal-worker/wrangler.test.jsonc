{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "zx-signal-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "zx-signal-test",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "ZX_SIGNAL_LLM_API_URL": "https://gateway.test/api/ai/stream",
    "ZX_SIGNAL_LLM_API_TOKEN": "test-gateway-token",
    "ZX_SIGNAL_LLM_LABEL": "test-project-gateway",
    "ZX_SIGNAL_USER_AGENT": "zxlab-signal-test/0.2",
    "ZX_SIGNAL_ALLOWED_ORIGINS": "http://localhost:4321",
    "ZX_SIGNAL_ACCESS_ENABLED": "false",
    "ZX_SIGNAL_SCHEDULE_ENABLED": "false",
    "CF_ACCESS_TEAM_DOMAIN": "https://zxdx1.cloudflareaccess.com",
    "CF_ACCESS_AUD": "7559429b1da91fe218c27db2cdee8c70cec97195d9b86a0effea1b1916f84e64",
    "ZX_SIGNAL_WRITE_TOKEN": "test-only-not-a-secret"
  }
}
