{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "zx-signal-remote-dev",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "ai": { "binding": "AI", "remote": true },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "zx-signal",
      "database_id": "2968cf60-f38f-4488-8a83-2479d4ba3ee2",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "ZX_SIGNAL_EDITOR_MODEL": "@cf/openai/gpt-oss-20b",
    "ZX_SIGNAL_REPLY_MODEL": "@cf/openai/gpt-oss-20b",
    "ZX_SIGNAL_MEMORY_MODEL": "@cf/openai/gpt-oss-20b",
    "ZX_SIGNAL_GATEWAY_ID": "zx-signal",
    "ZX_SIGNAL_ALLOWED_ORIGINS": "https://zx-dx.xyz,http://localhost:4321",
    "ZX_SIGNAL_ACCESS_ENABLED": "false"
  }
}
