{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node"]
  },
  "include": [
    "src/lib/ai/**/*.ts",
    "src/features/risk/**/*.ts",
    "functions/_lib/ai/**/*.ts",
    "functions/_lib/risk/**/*.ts",
    "functions/_lib/market/**/*.ts",
    "functions/api/ai/**/*.ts",
    "functions/api/status/llm.ts",
    "functions/api/risk/**/*.ts",
    "functions/api/market/**/*.ts",
    "tests/ai-gateway.test.ts",
    "tests/risk-review-api.test.ts",
    "tests/risk-market.test.ts"
  ],
  "exclude": ["dist", "apps", "services", "node_modules"]
}
