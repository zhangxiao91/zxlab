---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "zxlab",
  description = "A personal lab for projects, notes, and experiments.",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="description" />
    <title>{title}</title>
  </head>
  <body>
    <body>
      <div class="site-shell">
        <SiteHeader />
        <slot />
        <SiteFooter />
      </div>
    </body>
  </body>
</html>
