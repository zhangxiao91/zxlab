---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { welcomeGateConfig } from "../components/welcome/welcome-config";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  welcomeGate?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
  title = "zxlab",
  description = "A personal lab for projects, notes, and experiments.",
  lang = "en",
  welcomeGate = false,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {
      welcomeGate && (
        <script
          is:inline
          define:vars={{
            enabled: welcomeGateConfig.enabled,
            storageKey: welcomeGateConfig.storageKey,
            replayQueryKey: welcomeGateConfig.replayQueryKey,
            failsafeDuration: welcomeGateConfig.failsafeDuration,
          }}
        >
          (() => {
            const html = document.documentElement;
            const url = new URL(window.location.href);
            const forceReplay = url.searchParams.get(replayQueryKey) === "1";

            if (forceReplay) {
              url.searchParams.delete(replayQueryKey);
              const cleanUrl = url.pathname + url.search + url.hash;
              window.history.replaceState(window.history.state, "", cleanUrl);
            }

            let hasSeenWelcome = false;
            try {
              hasSeenWelcome = window.sessionStorage.getItem(storageKey) === "1";
            } catch {}

            const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
            const shouldShow = enabled && !reducedMotion && (forceReplay || !hasSeenWelcome);

            if (!shouldShow) return;

            html.classList.add("welcome-pending");
            window.__zxWelcomeFailsafe = window.setTimeout(() => {
              html.classList.remove("welcome-pending", "welcome-active", "welcome-leaving");
              document.body?.classList.remove("welcome-locked");
              document.querySelector(".site-shell")?.removeAttribute("inert");
              html.style.removeProperty("--welcome-scrollbar-gap");
            }, failsafeDuration);
          })();
        </script>
      )
    }
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader />
      <slot />
      <SiteFooter />
    </div>
    <slot name="overlay" />
  </body>
</html>
