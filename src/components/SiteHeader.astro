---
const pathname = Astro.url.pathname;

function isCurrent(href: string) {
	return href === "/" ? pathname === "/" : pathname.startsWith(href);
}
---

<header class="site-header">
	<a class="site-name" href="/">zxlab</a>

	<button
		class="site-menu-toggle"
		type="button"
		aria-controls="site-navigation"
		aria-expanded="false"
		aria-label="Open navigation"
	>
		<span aria-hidden="true"></span>
		<span aria-hidden="true"></span>
	</button>

	<nav class="site-nav" id="site-navigation" aria-label="Main navigation">
		<a
			href="/briefing"
			aria-current={isCurrent("/briefing") ? "page" : undefined}
		>
			Signal
		</a>

		<a
			href="/projects"
			aria-current={isCurrent("/projects") ? "page" : undefined}
		>
			Projects
		</a>

		<a
			href="/notes"
			aria-current={isCurrent("/notes") ? "page" : undefined}
		>
			Notes
		</a>

		<a
			href="/lab"
			aria-current={isCurrent("/lab") ? "page" : undefined}
		>
			Lab
		</a>

		<a
			href="/status"
			aria-current={isCurrent("/status") ? "page" : undefined}
		>
			Status
		</a>

		<a
			href="/about"
			aria-current={isCurrent("/about") ? "page" : undefined}
		>
			About
		</a>
	</nav>
</header>

<script>
	import gsap from "gsap";

	const header = document.querySelector<HTMLElement>(".site-header");
	const toggle = header?.querySelector<HTMLButtonElement>(".site-menu-toggle");
	const navigation = header?.querySelector<HTMLElement>(".site-nav");

	if (header && toggle && navigation && header.dataset.menuBound !== "true") {
		header.dataset.menuBound = "true";
		header.dataset.menuReady = "true";
		const links = Array.from(navigation.querySelectorAll<HTMLElement>("a"));
		const mobileQuery = window.matchMedia("(max-width: 40rem)");
		const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
		let closeToken = 0;

		const prepareMotion = () => {
			const useGsap = mobileQuery.matches && !reducedMotion.matches;
			header.dataset.menuMotion = useGsap ? "gsap" : "css";
			gsap.killTweensOf([navigation, toggle, ...links]);
			gsap.set([navigation, toggle, ...links], { clearProps: "all" });
			if (useGsap && toggle.getAttribute("aria-expanded") !== "true") {
				gsap.set(navigation, { autoAlpha: 0, y: -10, scale: 0.965 });
				gsap.set(links, { autoAlpha: 0, y: -8 });
			}
		};

		const setMenu = (open: boolean, restoreFocus = false) => {
			const token = ++closeToken;
			header.dataset.menuOpen = String(open);
			toggle.setAttribute("aria-expanded", String(open));
			toggle.setAttribute("aria-label", open ? "Close navigation" : "Open navigation");

			if (header.dataset.menuMotion === "gsap") {
				gsap.killTweensOf([navigation, ...links]);
				if (open) {
					gsap.set(navigation, { visibility: "visible", pointerEvents: "auto" });
					gsap.to(navigation, {
						autoAlpha: 1,
						y: 0,
						scale: 1,
						duration: 0.46,
						ease: "power4.out",
						overwrite: "auto",
					});
					gsap.to(links, {
						autoAlpha: 1,
						y: 0,
						duration: 0.38,
						stagger: 0.035,
						delay: 0.05,
						ease: "power3.out",
						overwrite: "auto",
					});
				} else {
					gsap.to(links, {
						autoAlpha: 0,
						y: -6,
						duration: 0.18,
						stagger: { each: 0.018, from: "end" },
						ease: "power2.in",
						overwrite: "auto",
					});
					gsap.to(navigation, {
						autoAlpha: 0,
						y: -10,
						scale: 0.965,
						duration: 0.28,
						ease: "power3.in",
						overwrite: "auto",
						onComplete: () => {
							if (token !== closeToken || toggle.getAttribute("aria-expanded") === "true") return;
							gsap.set(navigation, { visibility: "hidden", pointerEvents: "none" });
						},
					});
				}
			}

			if (!open && restoreFocus) toggle.focus({ preventScroll: true });
		};

		toggle.addEventListener("pointerdown", () => {
			if (reducedMotion.matches) return;
			gsap.to(toggle, { scale: 0.92, duration: 0.1, ease: "power2.out", overwrite: true });
		}, { passive: true });
		const releaseToggle = () => gsap.to(toggle, { scale: 1, duration: 0.32, ease: "back.out(2)", overwrite: true });
		toggle.addEventListener("pointerup", releaseToggle, { passive: true });
		toggle.addEventListener("pointercancel", releaseToggle, { passive: true });

		toggle.addEventListener("click", () => {
			const now = performance.now();
			const previousToggle = Number(header.dataset.lastMenuToggle ?? 0);
			if (now - previousToggle < 240) return;
			header.dataset.lastMenuToggle = String(now);
			setMenu(toggle.getAttribute("aria-expanded") !== "true");
		});

		navigation.addEventListener("click", (event) => {
			if ((event.target as Element).closest("a")) setMenu(false);
		});

		document.addEventListener("click", (event) => {
			if (!header.contains(event.target as Node)) setMenu(false);
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
				setMenu(false, true);
			}
		});

		mobileQuery.addEventListener("change", () => {
			setMenu(false);
			prepareMotion();
		});
		reducedMotion.addEventListener("change", prepareMotion);
		prepareMotion();
	}
</script>
