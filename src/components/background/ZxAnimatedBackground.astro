---
import { BACKGROUND_CONFIG } from "./background-config";

function seededValue(index: number) {
  const value = Math.sin((index + 1) * 9283.17 + 47.11) * 43758.5453;
  return value - Math.floor(value);
}

function createRows(rowCount: number, columnCount: number, offset = 0) {
  return Array.from({ length: rowCount }, (_, rowIndex) =>
    Array.from({ length: columnCount }, (_, columnIndex) => {
      const index = offset + rowIndex * columnCount + columnIndex;
      return {
        value: "zx",
        style: seededValue(index + 101) > 0.8 ? "outline" : seededValue(index + 211) > 0.9 ? "glow" : "solid",
        size: seededValue(index + 307) > 0.72 ? "large" : seededValue(index + 401) < 0.2 ? "small" : "regular",
      };
    }),
  );
}

const farRows = createRows(6, 8);
const midRows = createRows(4, 5, 600);
const tileCopies = Array.from({ length: 4 });
const sparks = Array.from({ length: BACKGROUND_CONFIG.sparkCount }, (_, index) => ({
  x: 4 + seededValue(index + 801) * 92,
  y: -8 + seededValue(index + 901) * 92,
  size: 1 + seededValue(index + 1001) * 2,
  duration: 10 + seededValue(index + 1101) * 10,
  delay: seededValue(index + 1201) * -18,
  opacity: 0.28 + seededValue(index + 1301) * 0.45,
}));
---

<div
  class="zx-background"
  data-zx-background
  aria-hidden="true"
  style={`--zx-pattern-angle:${BACKGROUND_CONFIG.patternAngle}deg;--zx-far-opacity:${BACKGROUND_CONFIG.farOpacity};--zx-far-motion-duration:${BACKGROUND_CONFIG.farDuration}s;--zx-mid-opacity:${BACKGROUND_CONFIG.midOpacity};--zx-mid-motion-duration:${BACKGROUND_CONFIG.midDuration}s`}
>
  <div class="zx-background__gradient"></div>

  <div class="zx-pattern zx-pattern--far" data-zx-pattern="far">
    <div class="zx-pattern__track">
      {tileCopies.map(() => (
        <div class="zx-pattern__tile">
          {farRows.map((row, rowIndex) => (
            <div class:list={["zx-pattern__row", { "zx-pattern__row--offset": rowIndex % 2 === 1 }]}>
              {row.map((token) => <span class:list={["zx-pattern__token", `is-${token.style}`, `is-${token.size}`]}>{token.value}</span>)}
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div class="zx-sparks" aria-hidden="true">
    {sparks.map((spark) => (
      <i style={`--spark-x:${spark.x.toFixed(2)}%;--spark-y:${spark.y.toFixed(2)}%;--spark-size:${spark.size.toFixed(2)}px;--spark-duration:${spark.duration.toFixed(2)}s;--spark-delay:${spark.delay.toFixed(2)}s;--spark-opacity:${spark.opacity.toFixed(2)}`}></i>
    ))}
  </div>

  <div class="zx-pattern zx-pattern--mid" data-zx-pattern="mid">
    <div class="zx-pattern__track">
      {tileCopies.map(() => (
        <div class="zx-pattern__tile">
          {midRows.map((row, rowIndex) => (
            <div class:list={["zx-pattern__row", { "zx-pattern__row--offset": rowIndex % 2 === 1 }]}>
              {row.map((token) => <span class:list={["zx-pattern__token", `is-${token.style}`, `is-${token.size}`]}>{token.value}</span>)}
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div class="zx-meteors" data-zx-meteors></div>
  <div class="zx-background__readability"></div>
</div>

<script>
  import { BACKGROUND_CONFIG, METEOR_CONFIG } from "./background-config";
  import { getMotionController, motionStateEvent, type MotionState } from "./motion-state";

  const background = document.querySelector("[data-zx-background]");

  if (background instanceof HTMLElement && background.dataset.initialized !== "true") {
    background.dataset.initialized = "true";
    const meteorLayer = background.querySelector("[data-zx-meteors]");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const mobileViewport = window.matchMedia("(max-width: 40rem)");
    const motion = getMotionController();
    const timers = new Set();
    const activeEffects = new Set();
    let disposed = false;
    let animationFrame = 0;
    let previousScrollY = window.scrollY;
    let pendingScrollY = window.scrollY;
    let smoothedVelocity = 0;
    let lastSpawnTime = 0;
    let lastScrollTime = 0;
    let ambientTimer = 0;
    let lastPatternSpeed = -1;
    let lastMotionPublish = 0;
    let lastPointerX = 0;
    let lastPointerY = 0;
    let lastPointerTime = 0;
    let lastPointerSpawn = 0;

    const randomBetween = (minimum, maximum) => minimum + Math.random() * (maximum - minimum);
    const clamp = (value, minimum, maximum) => Math.min(maximum, Math.max(minimum, value));
    const mix = (minimum, maximum, amount) => minimum + (maximum - minimum) * amount;
    const setTimer = (callback, delay) => {
      const timer = window.setTimeout(() => {
        timers.delete(timer);
        callback();
      }, delay);
      timers.add(timer);
      return timer;
    };
    const clearTimers = () => {
      timers.forEach((timer) => window.clearTimeout(timer));
      timers.clear();
      ambientTimer = 0;
    };

    const getRangeFade = (startViewport: number, endViewport: number) => {
      const fadeStart = window.innerHeight * startViewport;
      const fadeEnd = window.innerHeight * endViewport;
      return 1 - clamp((window.scrollY - fadeStart) / (fadeEnd - fadeStart), 0, 1);
    };

    const getMotionFade = () => getRangeFade(METEOR_CONFIG.motionFadeStartViewport, METEOR_CONFIG.motionFadeEndViewport);
    const getAmbientFade = () => getRangeFade(METEOR_CONFIG.ambientFadeStartViewport, METEOR_CONFIG.ambientFadeEndViewport);

    const removeEffect = (effect) => {
      activeEffects.delete(effect);
      effect.remove();
    };

    const launchEffect = ({
      intensity = 0.2,
      direction = 1,
      trace = false,
      ambient = false,
      pointerAngle,
      pointerX,
      pointerY,
    }: {
      intensity?: number;
      direction?: number;
      trace?: boolean;
      ambient?: boolean;
      pointerAngle?: number;
      pointerX?: number;
      pointerY?: number;
    } = {}) => {
      if (disposed || reducedMotion.matches || document.hidden || !(meteorLayer instanceof HTMLElement)) return;
      const isMobile = mobileViewport.matches;
      const maximumCount = isMobile ? METEOR_CONFIG.mobileMaxActiveCount : METEOR_CONFIG.maxActiveCount;
      if (activeEffects.size >= maximumCount || getMotionFade() <= 0.02) return;

      const meteor = document.createElement("span");
      const mobileLengthScale = isMobile ? 0.8 : 1;
      const length = trace ? mix(30, 100, intensity) : mix(METEOR_CONFIG.minLength, METEOR_CONFIG.maxLength, intensity);
      const duration = trace ? mix(450, 180, intensity) : mix(METEOR_CONFIG.maxDuration, METEOR_CONFIG.minDuration, intensity);
      const angleJitter = randomBetween(-12, 12);
      const baseAngle = pointerAngle ?? (direction > 0 ? -138 : 42);
      const movementAngle = baseAngle + angleJitter;
      const trailAngle = movementAngle + 180;
      const radians = movementAngle * Math.PI / 180;
      const distance = trace ? mix(14, 26, intensity) : mix(34, 58, intensity);
      const startX = pointerX ?? (direction > 0 ? randomBetween(44, 112) : randomBetween(-12, 56));
      const startY = pointerY ?? (direction > 0 ? randomBetween(52, 112) : randomBetween(-12, 48));
      const strength = trace ? mix(0.16, 0.36, intensity) : ambient ? 0.42 : mix(0.42, 0.88, intensity);
      const blur = trace ? mix(0.5, 1.5, intensity) : mix(1.5, 4, intensity);

      meteor.className = `zx-meteor${trace ? " is-trace" : ""}`;
      if (!trace) meteor.innerHTML = "<i></i>";
      meteor.style.cssText = `--meteor-x:${startX.toFixed(2)}%;--meteor-y:${startY.toFixed(2)}%;--meteor-distance-x:${(Math.cos(radians) * distance).toFixed(2)}vw;--meteor-distance-y:${(Math.sin(radians) * distance).toFixed(2)}vh;--meteor-angle:${trailAngle.toFixed(2)}deg;--meteor-length:${(length * mobileLengthScale).toFixed(2)}px;--meteor-head:${mix(METEOR_CONFIG.minHeadSize, METEOR_CONFIG.maxHeadSize, intensity).toFixed(2)}px;--meteor-duration:${duration.toFixed(0)}ms;--meteor-strength:${strength.toFixed(2)};--meteor-blur:${blur.toFixed(2)}px`;
      meteor.addEventListener("animationend", () => removeEffect(meteor), { once: true });
      activeEffects.add(meteor);
      meteorLayer.append(meteor);
    };

    const launchScrollGroup = (intensity, direction) => {
      const isMobile = mobileViewport.matches;
      const meteorCount = Math.min(isMobile ? 2 : 4, Math.max(1, Math.ceil(mix(1, 4, intensity))));
      const traceCount = Math.min(isMobile ? 1 : 2, Math.floor(mix(1, 3, intensity)));
      for (let index = 0; index < meteorCount; index += 1) {
        launchEffect({ intensity: clamp(intensity + randomBetween(-0.12, 0.1), 0, 1), direction });
      }
      for (let index = 0; index < traceCount; index += 1) {
        launchEffect({ intensity, direction, trace: true });
      }
    };

    const applySharedMotion = (state: MotionState) => {
      const patternSpeed = Math.max(0.2, state.patternSpeed || 1);
      if (Math.abs(patternSpeed - lastPatternSpeed) >= 0.06) {
        lastPatternSpeed = patternSpeed;
        background.style.setProperty("--zx-far-motion-duration", `${BACKGROUND_CONFIG.farDuration / patternSpeed}s`);
        background.style.setProperty("--zx-mid-motion-duration", `${BACKGROUND_CONFIG.midDuration / patternSpeed}s`);
      }

      if ((state.phase === "intro-hit" || state.phase === "intro-transition") && state.meteorIntensity > 0.2) {
        smoothedVelocity = Math.max(smoothedVelocity, Math.abs(state.velocity || 28));
        pendingScrollY = previousScrollY;
        lastScrollTime = performance.now();
        launchScrollGroup(state.meteorIntensity, state.direction || 1);
        if (!animationFrame) animationFrame = requestAnimationFrame(updateFrame);
      }
    };

    const handleSharedMotion = (event: Event) => applySharedMotion((event as CustomEvent<MotionState>).detail);

    const scheduleAmbient = () => {
      if (ambientTimer || disposed || reducedMotion.matches || document.hidden || getMotionFade() <= 0.02) return;
      ambientTimer = setTimer(() => {
        ambientTimer = 0;
        if (performance.now() - lastScrollTime > 800) launchEffect({ intensity: 0.18, direction: 1, ambient: true });
        scheduleAmbient();
      }, randomBetween(METEOR_CONFIG.ambientMinInterval, METEOR_CONFIG.ambientMaxInterval));
    };

    const updateFrame = (time) => {
      animationFrame = 0;
      if (disposed || reducedMotion.matches || document.hidden) return;

      const delta = pendingScrollY - previousScrollY;
      previousScrollY = pendingScrollY;
      if (Math.abs(delta) > 0.01) smoothedVelocity = smoothedVelocity * 0.82 + delta * 0.18;
      else if (time - lastScrollTime > 80) smoothedVelocity *= 0.88;

      const intensity = clamp(Math.abs(smoothedVelocity) / 30, 0, 1);
      const motionFade = getMotionFade();
      const ambientFade = getAmbientFade();
      background.style.setProperty("--zx-motion-fade", motionFade.toFixed(3));
      background.style.setProperty("--zx-ambient-fade", ambientFade.toFixed(3));

      if (!motion.state.phase.startsWith("intro") && time - lastMotionPublish >= 80) {
        lastMotionPublish = time;
        motion.update({
          phase: intensity > 0.02 ? "scrolling" : "hero-idle",
          intensity,
          direction: smoothedVelocity > 0.08 ? 1 : smoothedVelocity < -0.08 ? -1 : 0,
          velocity: smoothedVelocity,
          patternSpeed: 1,
          meteorIntensity: intensity,
          glitchIntensity: 0,
        });
      }

      if (motionFade <= 0.02) {
        activeEffects.forEach(removeEffect);
        smoothedVelocity = 0;
        return;
      }

      if (intensity > 0.02) {
        const spawnInterval = mix(180, 90, intensity);
        if (time - lastSpawnTime >= spawnInterval) {
          launchScrollGroup(intensity, smoothedVelocity >= 0 ? 1 : -1);
          lastSpawnTime = time;
        }
      }

      if (Math.abs(smoothedVelocity) > 0.08 || time - lastScrollTime < 600) {
        animationFrame = requestAnimationFrame(updateFrame);
      }
    };

    const handleScroll = () => {
      pendingScrollY = window.scrollY;
      lastScrollTime = performance.now();
      scheduleAmbient();
      if (!animationFrame && !reducedMotion.matches && !document.hidden) {
        animationFrame = requestAnimationFrame(updateFrame);
      }
    };

    const handlePointerMove = (event: PointerEvent) => {
      if (mobileViewport.matches || event.pointerType === "touch" || reducedMotion.matches || document.hidden) return;

      const now = event.timeStamp;
      if (!lastPointerTime) {
        lastPointerX = event.clientX;
        lastPointerY = event.clientY;
        lastPointerTime = now;
        return;
      }

      const deltaX = event.clientX - lastPointerX;
      const deltaY = event.clientY - lastPointerY;
      const elapsed = Math.max(8, now - lastPointerTime);
      const speed = Math.hypot(deltaX, deltaY) / elapsed;
      lastPointerX = event.clientX;
      lastPointerY = event.clientY;
      lastPointerTime = now;

      if (speed < 0.18) return;
      const intensity = clamp(speed / 1.4, 0.12, 0.82);
      const spawnInterval = mix(170, 75, intensity);
      if (now - lastPointerSpawn < spawnInterval) return;
      lastPointerSpawn = now;

      const pointerAngle = Math.atan2(deltaY, deltaX) * 180 / Math.PI;
      const pointerX = clamp(event.clientX / window.innerWidth * 100, 0, 100);
      const pointerY = clamp(event.clientY / window.innerHeight * 100, 0, 100);
      launchEffect({ intensity, pointerAngle, pointerX, pointerY });
      if (intensity > 0.56) launchEffect({ intensity: intensity * 0.72, trace: true, pointerAngle, pointerX, pointerY });
    };

    const resetEffects = () => {
      activeEffects.forEach((effect) => effect.remove());
      activeEffects.clear();
      if (meteorLayer instanceof HTMLElement) meteorLayer.replaceChildren();
    };
    const handleVisibility = () => {
      clearTimers();
      if (animationFrame) cancelAnimationFrame(animationFrame);
      animationFrame = 0;
      resetEffects();
      if (!document.hidden && !reducedMotion.matches) {
        previousScrollY = pendingScrollY = window.scrollY;
        scheduleAmbient();
      }
    };
    const handleMotionPreference = () => {
      clearTimers();
      if (animationFrame) cancelAnimationFrame(animationFrame);
      animationFrame = 0;
      resetEffects();
      if (!reducedMotion.matches) scheduleAmbient();
    };
    const cleanup = () => {
      disposed = true;
      clearTimers();
      if (animationFrame) cancelAnimationFrame(animationFrame);
      resetEffects();
      window.removeEventListener("scroll", handleScroll);
      window.removeEventListener("pointermove", handlePointerMove);
      window.removeEventListener(motionStateEvent, handleSharedMotion);
      document.removeEventListener("visibilitychange", handleVisibility);
      document.removeEventListener("astro:before-swap", cleanup);
      window.removeEventListener("pagehide", cleanup);
      reducedMotion.removeEventListener("change", handleMotionPreference);
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    window.addEventListener("pointermove", handlePointerMove, { passive: true });
    window.addEventListener(motionStateEvent, handleSharedMotion);
    document.addEventListener("visibilitychange", handleVisibility);
    document.addEventListener("astro:before-swap", cleanup, { once: true });
    window.addEventListener("pagehide", cleanup, { once: true });
    reducedMotion.addEventListener("change", handleMotionPreference);
    background.style.setProperty("--zx-motion-fade", getMotionFade().toFixed(3));
    background.style.setProperty("--zx-ambient-fade", getAmbientFade().toFixed(3));
    applySharedMotion(motion.state);
    scheduleAmbient();
  }
</script>

<style>
  .zx-background {
    position: fixed;
    inset: 0;
    height: 100svh;
    z-index: 0;
    overflow: hidden;
    opacity: 1;
    pointer-events: none;
    user-select: none;
    backface-visibility: hidden;
    contain: strict;
    isolation: isolate;
    transform: translateZ(0);
    transition: opacity 120ms linear;
  }

  .zx-background__gradient,
  .zx-pattern,
  .zx-sparks,
  .zx-meteors,
  .zx-background__readability {
    position: absolute;
    inset: 0;
  }

  .zx-background__gradient {
    z-index: 0;
    inset: -8%;
    background:
      radial-gradient(ellipse at 50% 24%, rgba(74, 91, 176, 0.5), transparent 38%),
      radial-gradient(circle at 13% 76%, rgba(44, 132, 156, 0.2), transparent 32%),
      radial-gradient(circle at 88% 20%, rgba(122, 78, 161, 0.22), transparent 30%),
      linear-gradient(145deg, #060a16 4%, #091126 42%, #11183a 68%, #070a16 100%);
    animation: zx-gradient-breathe 24s ease-in-out infinite alternate;
    opacity: var(--zx-ambient-fade, 1);
  }

  .zx-pattern {
    transform: rotate(var(--zx-pattern-angle));
    transform-origin: center;
  }

  .zx-pattern--far {
    z-index: 1;
    inset: -20%;
    opacity: var(--zx-far-opacity);
  }

  .zx-pattern--mid {
    z-index: 3;
    inset: -28%;
    opacity: var(--zx-mid-opacity);
  }

  .zx-pattern__track {
    display: grid;
    width: 200%;
    height: 200%;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 1fr);
    backface-visibility: hidden;
    will-change: transform;
  }

  .zx-pattern--far .zx-pattern__track { animation: zx-pattern-far var(--zx-far-motion-duration) linear infinite; }
  .zx-pattern--mid .zx-pattern__track { animation: zx-pattern-mid var(--zx-mid-motion-duration) linear infinite; }
  .zx-pattern--far .zx-pattern__track { opacity: var(--zx-ambient-fade, 1); }
  .zx-pattern--mid .zx-pattern__track { opacity: var(--zx-motion-fade, 1); }
  .zx-pattern__tile { display: grid; min-width: 0; align-content: space-evenly; }
  .zx-pattern__row { display: grid; align-items: center; }
  .zx-pattern--far .zx-pattern__row { grid-template-columns: repeat(8, minmax(2.4rem, 1fr)); column-gap: clamp(2.4rem, 4vw, 5rem); }
  .zx-pattern--mid .zx-pattern__row { grid-template-columns: repeat(5, minmax(5rem, 1fr)); column-gap: clamp(5rem, 9vw, 10rem); }
  .zx-pattern__row--offset { transform: translateX(clamp(3rem, 6vw, 7rem)); }

  .zx-pattern__token {
    color: #dce9ff;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-weight: 600;
    letter-spacing: -0.09em;
    white-space: nowrap;
  }
  .zx-pattern--far .zx-pattern__token { font-size: clamp(1.125rem, 1.8vw, 1.875rem); }
  .zx-pattern--mid .zx-pattern__token { font-size: clamp(2.25rem, 4vw, 4.5rem); }
  .zx-pattern__token.is-small { font-size: 0.78em; }
  .zx-pattern__token.is-large { font-size: 1.18em; }
  .zx-pattern__token.is-outline { color: transparent; -webkit-text-stroke: 1px rgba(176, 184, 255, 0.94); }
  .zx-pattern__token.is-glow { color: #c8ecff; text-shadow: 0 0 12px rgba(89, 174, 255, 0.62); }
  .zx-pattern__token:nth-child(4n) { color: #c8c8ff; }

  .zx-sparks { z-index: 2; overflow: hidden; opacity: var(--zx-motion-fade, 1); }
  .zx-sparks i {
    position: absolute;
    top: var(--spark-y);
    left: var(--spark-x);
    width: var(--spark-size);
    height: var(--spark-size);
    border-radius: 50%;
    background: #d9efff;
    box-shadow: 0 0 7px rgba(102, 181, 255, 0.68);
    opacity: var(--spark-opacity);
    animation: zx-spark-drift var(--spark-duration) linear var(--spark-delay) infinite;
    will-change: transform, opacity;
  }
  .zx-sparks i:nth-child(3n) { animation-name: zx-spark-drift, zx-spark-twinkle; animation-duration: var(--spark-duration), 2.8s; animation-delay: var(--spark-delay), var(--spark-delay); }

  .zx-meteors {
    z-index: 4;
    overflow: hidden;
    opacity: var(--zx-motion-fade, 1);
  }
  :global(.zx-meteor) {
    position: absolute;
    top: var(--meteor-y);
    left: var(--meteor-x);
    width: var(--meteor-length);
    height: 2px;
    opacity: 0;
    transform: translate3d(0, 0, 0) rotate(var(--meteor-angle));
    transform-origin: left center;
    animation: zx-meteor-flight var(--meteor-duration) cubic-bezier(0.16, 0.7, 0.2, 1) both;
    will-change: transform, opacity;
  }
  :global(.zx-meteor)::before { position: absolute; inset: -9px -14px; background: radial-gradient(ellipse at 0 50%, rgba(130, 208, 255, 0.5), transparent 64%); content: ""; filter: blur(5px); }
  :global(.zx-meteor)::after { position: absolute; top: 50%; left: 0; width: var(--meteor-head); height: var(--meteor-head); border-radius: 50%; background: #f1fbff; box-shadow: 0 0 5px #fff, 0 0 14px rgba(99, 190, 255, 0.95); content: ""; transform: translate(-50%, -50%); }
  :global(.zx-meteor) i { display: block; width: 100%; height: 100%; background: linear-gradient(90deg, rgba(235, 249, 255, 0.98), rgba(130, 181, 255, 0.52) 38%, rgba(116, 99, 223, 0.14) 72%, transparent); }
  :global(.zx-meteor.is-trace) {
    height: 1px;
    filter: blur(var(--meteor-blur));
  }
  :global(.zx-meteor.is-trace)::before,
  :global(.zx-meteor.is-trace)::after { display: none; }
  :global(.zx-meteor.is-trace) { background: linear-gradient(90deg, rgba(179, 218, 255, 0.62), transparent); }

  .zx-background__readability {
    z-index: 5;
    opacity: var(--zx-ambient-fade, 1);
    background:
      linear-gradient(to bottom, rgba(3, 6, 14, 0.38), transparent 15%, transparent 76%, rgba(4, 7, 15, 0.24)),
      radial-gradient(ellipse at 50% 27%, rgba(6, 9, 21, 0.36) 0%, rgba(6, 9, 21, 0.18) 32%, transparent 61%);
  }

  @keyframes zx-gradient-breathe { from { transform: translate3d(-1.2%, -0.8%, 0) scale(1.04); } to { transform: translate3d(1.2%, 0.9%, 0) scale(1.06); } }
  @keyframes zx-pattern-far { from { transform: translate3d(0, -50%, 0); } to { transform: translate3d(-50%, 0, 0); } }
  @keyframes zx-pattern-mid { from { transform: translate3d(-2%, -50%, 0); } to { transform: translate3d(-52%, 0, 0); } }
  @keyframes zx-spark-drift { from { transform: translate3d(12vw, -10vh, 0); } to { transform: translate3d(-35vw, 38vh, 0); } }
  @keyframes zx-spark-twinkle { 0%, 100% { opacity: 0.18; } 50% { opacity: var(--spark-opacity); } }
  @keyframes zx-meteor-flight {
    0% { opacity: 0; transform: translate3d(0, 0, 0) rotate(var(--meteor-angle)) scaleX(0.72); }
    10% { opacity: var(--meteor-strength); }
    72% { opacity: var(--meteor-strength); }
    100% { opacity: 0; transform: translate3d(var(--meteor-distance-x), var(--meteor-distance-y), 0) rotate(var(--meteor-angle)) scaleX(1.08); }
  }

  @media (max-width: 40rem) {
    .zx-background { height: 100svh; transition: none; }
    .zx-background__gradient { animation: none; transform: scale(1.04); }
    .zx-pattern--far { display: none; }
    .zx-pattern--mid { inset: -20%; opacity: 0.14; }
    .zx-pattern--mid .zx-pattern__token { font-size: clamp(2.6rem, 12vw, 4.2rem); }
    .zx-pattern__token.is-glow { text-shadow: none; }
    .zx-sparks i:nth-child(n + 6) { display: none; }
    :global(.zx-meteor)::before { display: none; }
    :global(.zx-meteor)::after { box-shadow: 0 0 7px rgba(99, 190, 255, 0.72); }
    :global(.zx-meteor.is-trace) { filter: none; opacity: 0.72; }
    .zx-background__readability { background: linear-gradient(to bottom, rgba(3, 6, 14, 0.42), transparent 18%, transparent 70%, rgba(4, 7, 15, 0.24)), radial-gradient(ellipse at 50% 25%, rgba(6, 9, 21, 0.42), rgba(6, 9, 21, 0.16) 42%, transparent 70%); }
