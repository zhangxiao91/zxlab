---
import { HOME_HERO_WORDS } from "../../data/home-hero";
---

<div class="hero-word" data-yuragi-loop data-state="boot" aria-hidden="true">
  <svg viewBox="0 0 500 82" preserveAspectRatio="xMinYMid meet" focusable="false" data-word-svg>
    <g class="hero-word__glyphs" data-glyphs></g>
    <rect class="hero-word__cursor" data-cursor x="0" y="5" width="3" height="66" rx="1"></rect>
  </svg>
  <span class="hero-word__fallback">{HOME_HERO_WORDS[0]}</span>
</div>

<script>
  import {
    HOME_HERO_EVENT,
    HOME_HERO_TIMING,
    HOME_HERO_WORDS,
    type MotionState,
  } from "../../data/home-hero";
  import { welcomeFinishedEvent } from "../welcome/welcome-config";

  const SHARD_CLIPS = [
    "polygon(0 0, 53% 0, 47% 29%, 0 34%)",
    "polygon(53% 0, 100% 0, 100% 25%, 47% 29%)",
    "polygon(0 34%, 47% 29%, 54% 54%, 0 60%)",
    "polygon(47% 29%, 100% 25%, 100% 55%, 54% 54%)",
    "polygon(0 60%, 54% 54%, 45% 79%, 0 84%)",
    "polygon(54% 54%, 100% 55%, 100% 81%, 45% 79%)",
    "polygon(0 84%, 45% 79%, 51% 100%, 0 100%)",
    "polygon(45% 79%, 100% 81%, 100% 100%, 51% 100%)",
  ];
  const FONT = '500 70px "Geist", "Outfit", sans-serif';

  const root = document.querySelector<HTMLElement>("[data-yuragi-loop]");

  if (root && root.dataset.initialized !== "true") {
    root.dataset.initialized = "true";
    const glyphLayer = root.querySelector<SVGGElement>("[data-glyphs]");
    const cursor = root.querySelector<SVGRectElement>("[data-cursor]");
    const wordSvg = root.querySelector<SVGSVGElement>("[data-word-svg]");
    const hero = root.closest<HTMLElement>("[data-home-hero]");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const context = document.createElement("canvas").getContext("2d");
    const timers = new Set<number>();
    let observer: IntersectionObserver | undefined;
    let wordIndex = 0;
    let visibleCount = 0;
    let state: MotionState = "boot";
    let heroVisible = true;
    let disposed = false;

    const measure = (text: string) => {
      if (!context) return text.length * 48;
      context.font = FONT;
      return context.measureText(text).width;
    };
    const seeded = (a: number, b: number) => {
      const value = Math.sin((a + 1) * 9283.17 + (b + 1) * 47.11) * 43758.5453;
      return value - Math.floor(value);
    };
    const publish = (next: MotionState, intensity = 0) => {
      state = next;
      root.dataset.state = next;
      window.dispatchEvent(new CustomEvent(HOME_HERO_EVENT, { detail: { state: next, intensity } }));
    };
    const schedule = (callback: () => void, delay: number) => {
      const timer = window.setTimeout(() => {
        timers.delete(timer);
        if (!disposed && state !== "paused") callback();
      }, delay);
      timers.add(timer);
    };
    const clearTimers = () => {
      timers.forEach((timer) => window.clearTimeout(timer));
      timers.clear();
    };
    const currentWord = () => HOME_HERO_WORDS[wordIndex];
    const setCursor = () => cursor?.setAttribute("x", String(measure(currentWord().slice(0, visibleCount)) + 6));
    const setWordMetrics = () => {
      const word = currentWord();
      root.dataset.word = word;
      wordSvg?.setAttribute("viewBox", `0 0 ${Math.max(420, measure(word) + 18).toFixed(2)} 82`);
    };
    const createGlyph = (character: string, index: number) => {
      const namespace = "http://www.w3.org/2000/svg";
      const group = document.createElementNS(namespace, "g");
      group.classList.add("hero-glyph", "is-entering");
      group.dataset.character = character;
      group.setAttribute("transform", `translate(${measure(currentWord().slice(0, index)).toFixed(2)} 0)`);

      SHARD_CLIPS.forEach((clip, shardIndex) => {
        const shard = document.createElementNS(namespace, "text");
        shard.textContent = character;
        shard.setAttribute("x", "0");
        shard.setAttribute("y", "68");
        shard.style.clipPath = clip;
        shard.style.setProperty("--shard-x", `${((seeded(shardIndex, index + 8) - 0.5) * 54).toFixed(2)}px`);
        shard.style.setProperty("--shard-y", `${((seeded(index + 19, shardIndex) - 0.5) * 44).toFixed(2)}px`);
        shard.style.setProperty("--shard-r", `${((seeded(index + 37, shardIndex) - 0.5) * 48).toFixed(2)}deg`);
        shard.style.setProperty("--shard-delay", `${Math.round(seeded(shardIndex, index + 71) * 70)}ms`);
        group.append(shard);
      });
      return group;
    };
    const beginDelete = () => {
      if (!glyphLayer || visibleCount === 0) {
        publish("switching");
        wordIndex = (wordIndex + 1) % HOME_HERO_WORDS.length;
        setWordMetrics();
        schedule(beginTyping, HOME_HERO_TIMING.switchGap);
        return;
      }
      publish("deleting", 0.82);
      const target = glyphLayer.lastElementChild as SVGGElement | null;
      if (!target) return;
      target.classList.remove("is-entering");
      target.classList.add("is-exiting");
      schedule(() => {
        target.remove();
        visibleCount -= 1;
        setCursor();
        schedule(beginDelete, HOME_HERO_TIMING.deleteInterval);
      }, HOME_HERO_TIMING.glyphScatterDuration);
    };
    const holdWord = () => {
      publish("holding");
      root.classList.add("is-micro-glitch");
      schedule(() => root.classList.remove("is-micro-glitch"), 110);
      schedule(beginDelete, HOME_HERO_TIMING.holdDuration);
    };
    function beginTyping() {
      if (!glyphLayer) return;
      const word = currentWord();
      if (visibleCount >= word.length) {
        schedule(holdWord, HOME_HERO_TIMING.glyphSettleDuration);
        return;
      }
      publish("typing", 0.38);
      const glyph = createGlyph(word[visibleCount], visibleCount);
      glyphLayer.append(glyph);
      visibleCount += 1;
      setCursor();
      publish("settling", 0.72);
      schedule(() => glyph.classList.remove("is-entering"), HOME_HERO_TIMING.glyphSettleDuration);
      schedule(beginTyping, HOME_HERO_TIMING.typeIntervals[(visibleCount - 1) % HOME_HERO_TIMING.typeIntervals.length]);
    }
    const pause = () => {
      if (state === "paused") return;
      clearTimers();
      publish("paused");
    };
    const resume = () => {
      if (disposed || reducedMotion.matches || document.hidden || !heroVisible || state !== "paused") return;
      if (visibleCount >= currentWord().length) {
        publish("holding");
        schedule(beginDelete, 480);
      } else {
        publish("typing");
        schedule(beginTyping, 120);
      }
    };
    const renderStatic = () => {
      clearTimers();
      glyphLayer?.replaceChildren();
      visibleCount = 0;
      setWordMetrics();
      currentWord().split("").forEach((character, index) => {
        const glyph = createGlyph(character, index);
        glyph.classList.remove("is-entering");
        glyphLayer?.append(glyph);
        visibleCount += 1;
      });
      setCursor();
      publish("paused");
    };
    const handleVisibility = () => document.hidden ? pause() : resume();
    const handleReducedMotion = () => reducedMotion.matches ? renderStatic() : resume();
    const dispose = () => {
      disposed = true;
      clearTimers();
      observer?.disconnect();
      document.removeEventListener("visibilitychange", handleVisibility);
      reducedMotion.removeEventListener("change", handleReducedMotion);
      window.removeEventListener(welcomeFinishedEvent, startLoop);
      window.removeEventListener("pagehide", dispose);
    };
    async function startLoop() {
      if (disposed) return;
      await document.fonts?.ready;
      if (disposed) return;
      setWordMetrics();
      publish("boot");
      schedule(beginTyping, HOME_HERO_TIMING.bootDelay);
    }

    if (hero) {
      observer = new IntersectionObserver(([entry]) => {
        heroVisible = entry.isIntersecting;
        if (heroVisible) resume();
        else pause();
      }, { threshold: 0.04 });
      observer.observe(hero);
    }
    document.addEventListener("visibilitychange", handleVisibility);
    reducedMotion.addEventListener("change", handleReducedMotion);
    window.addEventListener("pagehide", dispose, { once: true });
    if (reducedMotion.matches) renderStatic();
    else if (document.documentElement.classList.contains("welcome-pending")) window.addEventListener(welcomeFinishedEvent, startLoop, { once: true });
    else startLoop();
  }
</script>
