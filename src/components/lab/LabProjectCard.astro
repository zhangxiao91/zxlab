---
import type { LabProject } from "../../lab/types";
import { getLabProjectHref } from "../../lab/projects";
import LabStatusBadge from "./LabStatusBadge.astro";

interface Props {
  project: LabProject;
  lead?: boolean;
}

const { project, lead = false } = Astro.props;
const href = getLabProjectHref(project);
const action = project.status === "coming-soon" ? "View planned experiment" : "Open experiment";
---

<a
  class:list={["lab-project-card", { "lab-project-card--lead": lead }]}
  href={href}
  target={project.external ? "_blank" : undefined}
  rel={project.external ? "noreferrer" : undefined}
>
  <div class="lab-project-card__media">
    {
      project.thumbnail && (
        <img src={project.thumbnail} alt={project.thumbnailAlt ?? ""} loading="lazy" data-lab-image />
      )
    }
  </div>
  <div class="lab-project-card__wash" aria-hidden="true"></div>
  <div class="lab-project-card__content">
    <div class="lab-project-card__topline">
      <LabStatusBadge status={project.status} />
      {project.category && <span>{project.category}</span>}
    </div>
    <div>
      <h3>{project.title}</h3>
      <p>{project.description}</p>
    </div>
    <div class="lab-project-card__footer">
      <span>{action}</span>
      <span class="lab-project-card__arrow" aria-hidden="true">↗</span>
    </div>
  </div>
</a>
