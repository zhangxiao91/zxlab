---
---

<aside class="boopi" data-boopi aria-label="Boopi desktop pet">
  <div class="boopi__bubble" data-boopi-bubble role="status" aria-live="polite">Boopi is watching the lab.</div>
  <div class="boopi__stage" data-boopi-drag-handle title="Drag Boopi around the lab">
    <div class="boopi__viewport">
      <div class="boopi__sprite" data-boopi-sprite aria-hidden="true"></div>
    </div>
    <button class="boopi__button" type="button" data-boopi-toggle aria-label="Minimize Boopi">×</button>
  </div>
  <button class="boopi__restore" type="button" data-boopi-restore aria-label="Bring Boopi back">Boopi</button>
</aside>

<style>
  .boopi {
    --boopi-scale: 0.72;
    position: fixed;
    right: clamp(1rem, 3vw, 2.5rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 20;
    display: grid;
    justify-items: end;
    pointer-events: none;
    user-select: none;
  }

  .boopi__bubble {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.3rem);
    max-width: 13rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid rgba(24, 25, 20, 0.12);
    border-radius: 0.9rem 0.9rem 0.2rem 0.9rem;
    background: rgba(247, 246, 239, 0.9);
    color: #3e4037;
    box-shadow: 0 0.7rem 2rem rgba(24, 25, 20, 0.1);
    font-size: 0.68rem;
    line-height: 1.35;
    opacity: 0;
    transform: translateY(0.4rem);
    transition: opacity 250ms ease, transform 250ms ease;
  }

  .boopi:hover .boopi__bubble,
  .boopi:focus-within .boopi__bubble { opacity: 1; transform: translateY(0); }

  .boopi__stage {
    position: relative;
    width: calc(192px * var(--boopi-scale));
    height: calc(208px * var(--boopi-scale));
    pointer-events: auto;
    cursor: grab;
    touch-action: none;
    filter: drop-shadow(0 0.8rem 0.8rem rgba(24, 25, 20, 0.14));
  }

  .boopi.is-dragging .boopi__stage { cursor: grabbing; }
  .boopi.is-dragging .boopi__bubble { opacity: 0; }

  .boopi__viewport {
    width: 192px;
    height: 208px;
    overflow: hidden;
    transform: scale(var(--boopi-scale));
    transform-origin: top left;
  }

  .boopi__sprite {
    width: 192px;
    height: 208px;
    background-image: url('/assets/lab/boopi/spritesheet.webp');
    background-repeat: no-repeat;
    background-size: 1536px 2288px;
    background-position: 0 0;
    image-rendering: auto;
    will-change: background-position;
  }

  .boopi__button {
    position: absolute;
    top: -0.25rem;
    right: -0.25rem;
    width: 1.35rem;
    height: 1.35rem;
    border: 1px solid rgba(24, 25, 20, 0.15);
    border-radius: 50%;
    background: #f7f6ef;
    color: #181914;
    cursor: pointer;
    font: inherit;
    line-height: 1;
    opacity: 0;
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .boopi:hover .boopi__button,
  .boopi:focus-within .boopi__button { opacity: 1; }
  .boopi__button:hover { transform: scale(1.08); }

  .boopi__restore {
    display: none;
    padding: 0.55rem 0.8rem;
    border: 1px solid rgba(24, 25, 20, 0.14);
    border-radius: 999px;
    background: rgba(247, 246, 239, 0.94);
    color: #181914;
    box-shadow: 0 0.7rem 2rem rgba(24, 25, 20, 0.12);
    cursor: pointer;
    font: 600 0.68rem/1 system-ui, sans-serif;
    pointer-events: auto;
  }

  .boopi.is-minimized .boopi__stage,
  .boopi.is-minimized .boopi__bubble { display: none; }
  .boopi.is-minimized .boopi__restore { display: block; }

  @media (max-width: 680px) {
    .boopi { --boopi-scale: 0.56; }
    .boopi__bubble { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .boopi__bubble { transition: none; }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-boopi]');
  const sprite = root?.querySelector<HTMLElement>('[data-boopi-sprite]');
  const bubble = root?.querySelector<HTMLElement>('[data-boopi-bubble]');
  const toggle = root?.querySelector<HTMLButtonElement>('[data-boopi-toggle]');
  const restore = root?.querySelector<HTMLButtonElement>('[data-boopi-restore]');
  const dragHandle = root?.querySelector<HTMLElement>('[data-boopi-drag-handle]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const positionKey = 'zxlab-boopi-position';
  const minimizedKey = 'zxlab-boopi-minimized';
  const cellWidth = 192;
  const cellHeight = 208;
  const states = {
    idle: { row: 0, frames: 6, frameMs: 360 },
    runningRight: { row: 1, frames: 8, frameMs: 145 },
    runningLeft: { row: 2, frames: 8, frameMs: 145 },
    waving: { row: 3, frames: 4, frameMs: 320 },
    jumping: { row: 4, frames: 5, frameMs: 240 },
    failed: { row: 5, frames: 8, frameMs: 320 },
    waiting: { row: 6, frames: 6, frameMs: 460 },
    working: { row: 7, frames: 6, frameMs: 460 },
    review: { row: 8, frames: 6, frameMs: 420 },
    looking: {
      cells: [
        ...Array.from({ length: 8 }, (_, column) => ({ row: 9, column })),
        ...Array.from({ length: 8 }, (_, column) => ({ row: 10, column })),
      ],
      frames: 16,
      frameMs: 320,
    },
  } as const;
  type State = keyof typeof states;
  const ambientActions: Array<{ state: State; message: string; weight: number }> = [
    { state: 'waving', message: 'Boopi noticed you.', weight: 3 },
    { state: 'waiting', message: 'Boopi is waiting for the next idea.', weight: 3 },
    { state: 'review', message: 'Boopi is checking the bench.', weight: 2 },
    { state: 'looking', message: 'Boopi is looking around the lab.', weight: 2 },
    { state: 'jumping', message: 'A small burst of lab energy.', weight: 1 },
  ];
  const manualActions: Array<{
    state: State;
    message: string;
    followUp?: { state: State; message: string };
  }> = [
    {
      state: 'working',
      message: 'Boopi is taking a careful look.',
      followUp: { state: 'review', message: 'Boopi has finished the thought.' },
    },
    {
      state: 'jumping',
      message: 'Boopi found something interesting.',
      followUp: { state: 'waving', message: 'Boopi wants to show you.' },
    },
    {
      state: 'looking',
      message: 'Boopi is scanning the whole lab.',
      followUp: { state: 'waiting', message: 'Boopi is ready for the next idea.' },
    },
    {
      state: 'failed',
      message: 'Boopi lost the thread for a moment.',
      followUp: { state: 'waving', message: 'Boopi is back.' },
    },
  ];
  let state: State = 'idle';
  let frame = 0;
  let completedLoops = 0;
  let frameTimer: number | undefined;
  let ambientTimer: number | undefined;
  let animationToken = 0;
  let dragged = false;
  let hovered = false;
  let manualSequence = false;
  let lastAmbientState: State | undefined;
  let manualActionIndex = Math.floor(Math.random() * manualActions.length);
  let dragDirection: 'left' | 'right' | undefined;

  const paint = () => {
    if (!sprite) return;
    const current = states[state];
    const cell = 'cells' in current
      ? current.cells[frame]
      : { row: current.row, column: frame };
    sprite.style.backgroundPosition = `${-cell.column * cellWidth}px ${-cell.row * cellHeight}px`;
  };

  const place = (left: number, top: number, save = false) => {
    if (!root) return;
    const rect = root.getBoundingClientRect();
    const margin = 8;
    const x = Math.min(Math.max(margin, left), Math.max(margin, window.innerWidth - rect.width - margin));
    const y = Math.min(Math.max(margin, top), Math.max(margin, window.innerHeight - rect.height - margin));
    root.style.left = `${x}px`;
    root.style.top = `${y}px`;
    root.style.right = 'auto';
    root.style.bottom = 'auto';
    if (save) localStorage.setItem(positionKey, JSON.stringify({ x, y }));
  };

  const restoreSavedPosition = () => {
    try {
      const saved = JSON.parse(localStorage.getItem(positionKey) || 'null');
      if (saved && Number.isFinite(saved.x) && Number.isFinite(saved.y)) place(saved.x, saved.y);
    } catch {}
  };

  const animate = (next: State, message: string, loops = Number.POSITIVE_INFINITY, done?: () => void) => {
    window.clearTimeout(frameTimer);
    const token = ++animationToken;
    state = next;
    if (root) root.dataset.state = next;
    frame = 0;
    completedLoops = 0;
    if (bubble) bubble.textContent = message;
    paint();

    if (reduced) {
      if (done) frameTimer = window.setTimeout(done, 900);
      return;
    }
    const tick = () => {
      if (token !== animationToken) return;
      const current = states[state];
      frame += 1;
      if (frame >= current.frames) {
        frame = 0;
        completedLoops += 1;
        if (completedLoops >= loops) {
          done?.();
          return;
        }
      }
      paint();
      frameTimer = window.setTimeout(tick, current.frameMs);
    };
    frameTimer = window.setTimeout(tick, states[next].frameMs);
  };

  const chooseAmbientAction = () => {
    const candidates = ambientActions.filter((action) => action.state !== lastAmbientState);
    const totalWeight = candidates.reduce((sum, action) => sum + action.weight, 0);
    let cursor = Math.random() * totalWeight;
    for (const action of candidates) {
      cursor -= action.weight;
      if (cursor <= 0) {
        lastAmbientState = action.state;
        return action;
      }
    }
    lastAmbientState = candidates[0].state;
    return candidates[0];
  };

  const scheduleAmbient = () => {
    window.clearTimeout(ambientTimer);
    if (reduced || hovered || manualSequence) return;
    ambientTimer = window.setTimeout(() => {
      const action = chooseAmbientAction();
      animate(action.state, action.message, 1, startIdle);
    }, 7200 + Math.random() * 6000);
  };

  function startIdle() {
    manualSequence = false;
    animate('idle', 'Boopi is watching the lab.');
    scheduleAmbient();
  }

  startIdle();
  root?.addEventListener('mouseenter', () => {
    hovered = true;
    window.clearTimeout(ambientTimer);
    if (!manualSequence) {
      animate('waving', 'A small hello from Boopi.', 1, () => {
        animate('idle', 'Boopi is watching the lab.');
      });
    }
  });
  root?.addEventListener('mouseleave', () => {
    hovered = false;
    if (!manualSequence) startIdle();
  });
  root?.addEventListener('click', (event) => {
    if ((event.target as HTMLElement).closest('button')) return;
    if (dragged) {
      dragged = false;
      return;
    }
    manualSequence = true;
    window.clearTimeout(ambientTimer);
    const action = manualActions[manualActionIndex];
    manualActionIndex = (manualActionIndex + 1) % manualActions.length;
    animate(action.state, action.message, 1, () => {
      if (!action.followUp) {
        startIdle();
        return;
      }
      animate(action.followUp.state, action.followUp.message, 1, startIdle);
    });
  });
  toggle?.addEventListener('click', () => {
    window.clearTimeout(frameTimer);
    window.clearTimeout(ambientTimer);
    animationToken += 1;
    root?.classList.add('is-minimized');
    localStorage.setItem(minimizedKey, '1');
  });
  restore?.addEventListener('click', () => {
    root?.classList.remove('is-minimized');
    localStorage.removeItem(minimizedKey);
    restoreSavedPosition();
    startIdle();
  });

  dragHandle?.addEventListener('pointerdown', (event) => {
    if (!root || (event.target as HTMLElement).closest('button')) return;
    const startRect = root.getBoundingClientRect();
    const offsetX = event.clientX - startRect.left;
    const offsetY = event.clientY - startRect.top;
    const startX = event.clientX;
    const startY = event.clientY;
    let previousX = event.clientX;
    dragged = false;
    dragDirection = undefined;
    root.classList.add('is-dragging');
    dragHandle.setPointerCapture(event.pointerId);

    const move = (moveEvent: PointerEvent) => {
      if (Math.hypot(moveEvent.clientX - startX, moveEvent.clientY - startY) > 4) {
        dragged = true;
        manualSequence = true;
        window.clearTimeout(ambientTimer);
        const deltaX = moveEvent.clientX - previousX;
        const nextDirection = deltaX < -1 ? 'left' : deltaX > 1 ? 'right' : dragDirection;
        if (nextDirection && nextDirection !== dragDirection) {
          dragDirection = nextDirection;
          animate(
            nextDirection === 'left' ? 'runningLeft' : 'runningRight',
            nextDirection === 'left' ? 'Boopi is moving left.' : 'Boopi is moving right.',
          );
        }
      }
      previousX = moveEvent.clientX;
      place(moveEvent.clientX - offsetX, moveEvent.clientY - offsetY);
    };
    const end = (endEvent: PointerEvent) => {
      root.classList.remove('is-dragging');
      dragHandle.releasePointerCapture(endEvent.pointerId);
      dragHandle.removeEventListener('pointermove', move);
      dragHandle.removeEventListener('pointerup', end);
      dragHandle.removeEventListener('pointercancel', end);
      const rect = root.getBoundingClientRect();
      place(rect.left, rect.top, true);
      if (dragged) startIdle();
    };
    dragHandle.addEventListener('pointermove', move);
    dragHandle.addEventListener('pointerup', end);
    dragHandle.addEventListener('pointercancel', end);
  });

  window.addEventListener('resize', () => {
    paint();
    if (!root || !root.style.left) return;
    const rect = root.getBoundingClientRect();
    place(rect.left, rect.top, true);
  });

  restoreSavedPosition();
  if (localStorage.getItem(minimizedKey) === '1') root?.classList.add('is-minimized');
</script>
