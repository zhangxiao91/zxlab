---
import Layout from "../layouts/Layout.astro";
import ProjectList from "../components/ProjectList.astro";
import { projects } from "../data/projects";
import { getCollection } from "astro:content";
import NoteList from "../components/NoteList.astro";

const featuredProjects = projects.filter((project) => project.featured);
const latestNotes = (await getCollection("notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 2);
---

<Layout
  title="zxlab"
  description="Zhangxiao's personal lab for projects, notes, and experiments."
>
  <main class="site-main">
    <section class="hero" aria-labelledby="intro-title">
      <p class="eyebrow">ZHANGXIAO / ZXLAB</p>

      <h1 id="intro-title">Building, learning, and experimenting.</h1>

      <p class="intro">
        A personal space for software projects, technical notes, and things I am
        currently exploring.
      </p>
    </section>
    <section class="home-section" aria-labelledby="projects-title">
      <div class="section-heading">
        <p class="section-index">01</p>
        <h2 id="projects-title">Selected projects</h2>
      </div>

      <ProjectList projects={featuredProjects} />
    </section>
    <section class="home-section" aria-labelledby="latest-notes-title">
      <div class="section-heading">
        <p class="section-index">02</p>
        <h2 id="latest-notes-title">Latest notes</h2>
      </div>

      <NoteList notes={latestNotes} />

      <p class="section-more">
        <a href="/notes">View all notes</a>
      </p>
    </section>
  </main>
</Layout>
