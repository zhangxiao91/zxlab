---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import referenceGraphData from "../../data/note-references.json";

interface InternalReference {
  targetKey: string;
  label: string;
  targetSlug?: string;
  targetTitle?: string;
  url?: string;
}

interface ReferenceNode {
  slug: string;
  title: string;
  sourceKey: string;
  outgoing: InternalReference[];
  backlinks: Array<{ slug: string; title: string; url: string }>;
  external: Array<{ label: string; domain: string; url: string }>;
  unpublished: Array<{ targetKey: string; label: string }>;
}

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => !data.draft);

  return notes.map((note) => ({
    params: { id: note.id },
    props: { note, notes },
  }));
}

interface Props {
  note: CollectionEntry<"notes">;
  notes: CollectionEntry<"notes">[];
}

const { note, notes } = Astro.props;
const { Content, headings } = await render(note);
const noteDate = note.data.updatedAt ?? note.data.publishedAt;
const sortedNotes = notes.filter(
  (item) => item.data.category === note.data.category,
).sort(
  (a, b) => (b.data.updatedAt ?? b.data.publishedAt).valueOf() - (a.data.updatedAt ?? a.data.publishedAt).valueOf(),
);
const noteIndex = sortedNotes.findIndex((item) => item.id === note.id);
const previousNote = sortedNotes[noteIndex + 1];
const nextNote = sortedNotes[noteIndex - 1];
const tableOfContents = headings.filter((heading) => heading.depth <= 3);
const cover = note.data.cover ?? "https://picsum.photos/seed/quiet-notebook/1800/1200";
const coverAlt = note.data.coverAlt ?? "Abstract monochrome notebook study";
const categoryLabel = note.data.category === "technical" ? "Technical note" : "Journal entry";
const referenceGraph = referenceGraphData as { version: 1; nodes: Record<string, ReferenceNode> };
const references = referenceGraph.nodes[note.id];
const hasConnections = Boolean(
  references && (references.outgoing.length || references.backlinks.length || references.external.length),
);
const canonicalNoteUrl = new URL(`/notes/${note.id}`, Astro.site).toString();
const citationUrls = references
  ? [...references.outgoing.flatMap((reference) => reference.url ? [reference.url] : []), ...references.external.map((reference) => reference.url)]
  : [];
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: note.data.title,
  description: note.data.description,
  datePublished: note.data.publishedAt.toISOString(),
  dateModified: noteDate.toISOString(),
  mainEntityOfPage: canonicalNoteUrl,
  url: canonicalNoteUrl,
  keywords: note.data.tags,
  ...(citationUrls.length ? { citation: citationUrls } : {}),
};
const articleJsonLdString = JSON.stringify(articleJsonLd).replace(/</g, "\\u003c");

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${note.data.title} | zxlab`} description={note.data.description}>
  <script type="application/ld+json" set:html={articleJsonLdString} />
  <main class="note-detail-page" style={`--note-accent: ${note.data.accent ?? "#d8ff73"}`}>
    <div class="reading-progress" aria-hidden="true">
      <span class="reading-progress__bar"></span>
    </div>

    <article class="longform-note">
      <header class="longform-hero">
        <div class="longform-hero__media" data-longform-image>
          <img src={cover} alt={coverAlt} fetchpriority="high" />
        </div>
        <div class="longform-hero__wash" aria-hidden="true"></div>

        <div class="longform-hero__content">
          <a href="/notes">← Back to notes</a>
          <time datetime={noteDate.toISOString()}>
            Updated {dateFormatter.format(noteDate)}
          </time>
          <h1>{note.data.title}</h1>
          <p>{note.data.description}</p>
        </div>
      </header>

      <div class="longform-layout">
        <aside class="longform-rail" aria-label="Article information">
          <div class="longform-rail__meta">
            <p>Filed under</p>
            <span class="longform-category">{categoryLabel}</span>
            <ul aria-label={`${note.data.title} tags`}>
              {note.data.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          </div>

          {
            tableOfContents.length > 0 && (
              <nav class="longform-toc" aria-label="Table of contents">
                <p>On this page</p>
                <ol>
                  {tableOfContents.map((heading) => (
                    <li class:list={[`longform-toc__depth-${heading.depth}`]}>
                      <a href={`#${heading.slug}`}>{heading.text}</a>
                    </li>
                  ))}
                </ol>
              </nav>
            )
          }
        </aside>

        <div class="longform-body prose">
          <Content />
        </div>
      </div>
    </article>

    {
      hasConnections && references && (
        <section class="note-connections" aria-labelledby="note-connections-title">
          <header class="note-connections__heading">
            <p>Connections</p>
            <h2 id="note-connections-title">Follow the ideas around this note.</h2>
          </header>

          <div class="note-connections__grid">
            {references.outgoing.length > 0 && (
              <div class="note-connection-group">
                <h3>Referenced here</h3>
                <ul>
                  {references.outgoing.map((reference) => (
                    <li>
                      <a href={reference.url ? new URL(reference.url).pathname + new URL(reference.url).hash : undefined}>
                        <span>{reference.targetTitle ?? reference.label}</span>
                        <small>{reference.label}</small>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {references.backlinks.length > 0 && (
              <div class="note-connection-group">
                <h3>Referenced by</h3>
                <ul>
                  {references.backlinks.map((reference) => (
                    <li>
                      <a href={new URL(reference.url).pathname}>
                        <span>{reference.title}</span>
                        <small>Open note</small>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {references.external.length > 0 && (
              <div class="note-connection-group note-connection-group--sources">
                <h3>Sources</h3>
                <ol>
                  {references.external.map((reference) => (
                    <li>
                      <a href={reference.url} target="_blank" rel="noreferrer">
                        <span>{reference.label}</span>
                        <small>{reference.domain}</small>
                      </a>
                    </li>
                  ))}
                </ol>
              </div>
            )}
          </div>
        </section>
      )
    }

    <section class="note-navigation" aria-labelledby="note-navigation-title">
      <div class="note-navigation__heading">
        <p>Keep reading</p>
        <h2 id="note-navigation-title">Follow the thread through the notebook.</h2>
      </div>

      {
        previousNote || nextNote ? (
          <div class="note-navigation__links">
            {previousNote && (
              <a href={`/notes/${previousNote.id}`}>
                <p>Previous note</p>
                <h3>{previousNote.data.title}</h3>
                <span aria-hidden="true">←</span>
              </a>
            )}
            {nextNote && (
              <a href={`/notes/${nextNote.id}`}>
                <p>Next note</p>
                <h3>{nextNote.data.title}</h3>
                <span aria-hidden="true">→</span>
              </a>
            )}
          </div>
        ) : (
          <a class="note-navigation__archive" href="/notes">
            <span>Return to the notes archive</span><span aria-hidden="true">↗</span>
          </a>
        )
      }
    </section>

    <section class="longform-cta" aria-labelledby="longform-cta-title">
      <p>Ideas become more useful when they return to the work.</p>
      <h2 id="longform-cta-title">Continue from the notebook into the projects.</h2>
      <a class="notes-button notes-button--light" href="/projects">
        <span>Explore projects</span><span aria-hidden="true">↗</span>
      </a>
    </section>
  </main>

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);
    const longformMotion = gsap.matchMedia();

    longformMotion.add("(prefers-reduced-motion: no-preference)", () => {
      gsap.from(".longform-hero__content > *", {
        y: 48,
        opacity: 0,
        duration: 1.08,
        stagger: 0.085,
        ease: "power3.out",
      });

      gsap.to(".reading-progress__bar", {
        scaleX: 1,
        ease: "none",
        scrollTrigger: {
          trigger: ".longform-note",
          start: "top top",
          end: "bottom bottom",
          scrub: true,
        },
      });

      gsap.utils.toArray<HTMLElement>(".longform-body img").forEach((image) => {
        gsap.fromTo(
          image,
          { scale: 0.88, opacity: 0.45 },
          {
            scale: 1,
            opacity: 1,
            ease: "none",
            scrollTrigger: {
              trigger: image,
              start: "top 90%",
              end: "top 48%",
              scrub: 0.8,
            },
          },
        );
      });
    });

    document.querySelectorAll<HTMLElement>(".longform-body pre").forEach((block) => {
      const code = block.querySelector("code");
      if (!code) return;

      const button = document.createElement("button");
      button.type = "button";
      button.className = "code-copy-button";
      button.textContent = "Copy";
      button.setAttribute("aria-label", "Copy code block");

      button.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(code.textContent ?? "");
          button.textContent = "Copied";
        } catch {
          button.textContent = "Copy unavailable";
        }
        window.setTimeout(() => {
          button.textContent = "Copy";
        }, 1600);
      });

      block.append(button);
    });

    const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>(".longform-toc a"));
    const articleHeadings = Array.from(
      document.querySelectorAll<HTMLElement>(".longform-body :is(h2[id], h3[id])"),
    );

    const headingObserver = new IntersectionObserver(
      (entries) => {
        const visibleHeading = entries.find((entry) => entry.isIntersecting);
        if (!visibleHeading) return;

        tocLinks.forEach((link) => link.removeAttribute("aria-current"));
        const activeLink = tocLinks.find(
          (link) => link.getAttribute("href") === `#${visibleHeading.target.id}`,
        );
        activeLink?.setAttribute("aria-current", "location");
      },
      { rootMargin: "-18% 0px -72% 0px" },
    );

    articleHeadings.forEach((heading) => headingObserver.observe(heading));
  </script>
</Layout>
