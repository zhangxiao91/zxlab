---
import Layout from "../layouts/Layout.astro";
import SystemStatusDashboard from "../components/status/SystemStatusDashboard.astro";
import "../styles/status.css";
---
<Layout title="Status | zxlab" description="Current health for zxlab systems and services.">
  <main class="status-page">
    <section class="status-hero" aria-labelledby="status-title">
      <div class="status-hero__copy"><p class="status-kicker">System control room</p><h1 id="status-title">A clear view of what is running.</h1><p class="status-hero__intro">Remote agents, memory, and the zxlab runtime in one privacy-aware status surface.</p></div>
    </section>
    <section class="status-dashboard-section" aria-label="zxlab system status"><SystemStatusDashboard /></section>
    <section class="status-cta" aria-labelledby="status-cta-title"><p>System signal, with boundaries intact.</p><h2 id="status-cta-title">Move from the control room into the experiments.</h2><a class="status-button" href="/lab">Open Lab <span aria-hidden="true">↗</span></a></section>
  </main>
</Layout>
