---
import Layout from "../layouts/Layout.astro";
import StatusDashboard from "../components/status/StatusDashboard.astro";
import { createMockStatusSnapshot } from "../status/providers/mock";
import "../styles/lab-status-shell.css";
import "../styles/status.css";

const snapshot = createMockStatusSnapshot("normal");
---

<Layout
  title="Status | zxlab"
  description="A public, privacy-filtered control room for ZXLab services, tool usage, devices, and recent activity."
>
  <main class="status-page">
    <section class="status-hero" aria-labelledby="status-title">
      <div class="status-hero__copy">
        <p class="status-kicker">ZX control room</p>
        <h1 id="status-title">
          Public signals,
          <span class="status-title-image" role="img" aria-label="Abstract control surface"></span>
          private boundaries.
        </h1>
        <p class="status-hero__intro">
          A visitor-facing structure for service health, tool usage, safe device
          presence, and the latest public development trail.
        </p>
      </div>

      <aside class="status-demo-notice" aria-label="Status data source notice" data-status-source-notice>
        <span aria-hidden="true"></span>
        <p data-status-notice-label>Demo snapshot</p>
        <h2 data-status-notice-title>No live or private provider is connected.</h2>
        <p data-status-notice-message>Every value below is illustrative and exists to verify the public data boundary.</p>
      </aside>
    </section>

    <section class="status-dashboard-section" aria-label="ZXLab public status dashboard">
      <StatusDashboard snapshot={snapshot} />
    </section>

    <section class="status-privacy" aria-labelledby="privacy-title">
      <p>Public by design</p>
      <div>
        <h2 id="privacy-title">Enough signal to be useful. No private network details.</h2>
        <p>
          Device addresses, SSH information, serial numbers, precise location,
          authentication data, and internal topology are outside this interface by type and policy.
        </p>
      </div>
    </section>

    <section class="status-cta" aria-labelledby="status-cta-title">
      <p>Status explains the surface. Lab holds what comes next.</p>
      <h2 id="status-cta-title">Move from the control room into the experiments.</h2>
      <a class="status-button" href="/lab"><span>Open Lab</span><span aria-hidden="true">↗</span></a>
    </section>
  </main>

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import {
      getStatusSnapshot,
      enhanceRelativeTimes,
      parseStatusScenario,
      renderLoadingSnapshot,
      renderStatusSnapshot,
      scheduleStatusRefresh,
      shouldLoadLiveStatus,
    } from "../status/client";
    import type { StatusSnapshot } from "../status/types";

    gsap.registerPlugin(ScrollTrigger);

    const dashboard = document.querySelector<HTMLElement>("[data-status-dashboard]");
    const refresh = document.querySelector<HTMLButtonElement>("[data-status-refresh]");
    const notice = document.querySelector<HTMLElement>("[data-status-source-notice]");
    const controller = new AbortController();
    const scenario = parseStatusScenario(new URL(window.location.href).searchParams.get("status-state"));
    const statusMotion = gsap.matchMedia();

    const updateSourceNotice = (snapshot: StatusSnapshot) => {
      if (!notice) return;
      const label = notice.querySelector<HTMLElement>("[data-status-notice-label]");
      const title = notice.querySelector<HTMLElement>("[data-status-notice-title]");
      const message = notice.querySelector<HTMLElement>("[data-status-notice-message]");
      const refreshLabel = refresh?.querySelector<HTMLElement>("span");
      if (snapshot.isMock) {
        if (label) label.textContent = "Demo snapshot";
        if (title) title.textContent = "No live or private provider is connected.";
        if (message) message.textContent = "Every value below is illustrative and exists to verify the public data boundary.";
        if (refreshLabel) refreshLabel.textContent = "Refresh demo";
        return;
      }

      const devicesLive = snapshot.devices.state === "ready" || snapshot.devices.state === "empty";
      const usageLive = snapshot.usage.state === "ready";
      if (label) label.textContent = devicesLive || usageLive ? "Live sources" : "Sources unavailable";
      if (title) title.textContent = devicesLive
        ? usageLive ? "Codex usage and device presence are connected." : "Tailscale device presence is connected."
        : usageLive ? "Codex usage is connected." : "The live sources could not be reached.";
      if (message) message.textContent = "Only normalized usage totals, allowlisted aliases, and coarse presence reach this public surface.";
      if (refreshLabel) refreshLabel.textContent = "Refresh status";
    };

    statusMotion.add("(prefers-reduced-motion: no-preference)", () => {
      gsap.from(".status-hero__copy > *, .status-demo-notice", {
        y: 48,
        opacity: 0,
        duration: 1.05,
        stagger: 0.08,
        ease: "power3.out",
      });

      gsap.utils.toArray<HTMLElement>(".status-overall, .status-module-grid, .status-activity").forEach((card) => {
        gsap.from(card, {
          y: 72,
          scale: 0.965,
          opacity: 0,
          duration: 1.1,
          ease: "power3.out",
          scrollTrigger: { trigger: card, start: "top 88%" },
        });
      });

      gsap.to(".status-overall", {
        y: -10,
        scale: 0.985,
        ease: "none",
        scrollTrigger: {
          trigger: ".status-module-grid",
          start: "top 82%",
          end: "top 18%",
          scrub: 0.8,
        },
      });
    });

    const refreshDashboard = async (delayMs = 650) => {
      if (!dashboard) return;
      renderLoadingSnapshot(dashboard);
      if (refresh) refresh.disabled = true;

      try {
        const nextScenario = scenario === "loading" ? "normal" : scenario;
        const nextSnapshot = await getStatusSnapshot(nextScenario, {
          signal: controller.signal,
          delayMs,
        });
        renderStatusSnapshot(dashboard, nextSnapshot);
        enhanceRelativeTimes(dashboard);
        updateSourceNotice(nextSnapshot);
      } catch {
        const errorSnapshot = await getStatusSnapshot("error");
        renderStatusSnapshot(dashboard, errorSnapshot);
      } finally {
        if (refresh) refresh.disabled = false;
      }
    };

    const formatTokens = (value: number | null | undefined) => value === null || value === undefined ? "N/A" : value >= 1_000_000 ? `${(value / 1_000_000).toFixed(2)}M` : value >= 1_000 ? `${(value / 1_000).toFixed(1)}K` : String(value);
    const formatCost = (value: number | null | undefined) => value === null || value === undefined ? "N/A" : `$${value < .01 ? value.toFixed(4) : value.toFixed(2)}`;
    const formatLatency = (value: number | null | undefined) => value === null || value === undefined ? "N/A" : value >= 1000 ? `${(value / 1000).toFixed(1)}s` : `${Math.round(value)}ms`;
    const escapeHtml = (value: unknown) => String(value ?? "").replace(/[&<>\"']/g, (character) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;" })[character]!);
    const setRows = (selector: string, rows: Array<string>) => { const root = document.querySelector<HTMLElement>(selector); if (root) root.innerHTML = rows.length ? rows.map((row) => `<li>${row}</li>`).join("") : "<li>No data in this range.</li>"; };
    const setMetrics = (selector: string, rows: Array<[string, string]>) => { const root = document.querySelector<HTMLElement>(selector); if (root) root.innerHTML = rows.map(([label, value]) => `<div><dt>${label}</dt><dd>${value}</dd></div>`).join(""); };
    const renderLLM = (data: any) => {
      const module = document.querySelector<HTMLElement>("[data-status-module='llm']"); if (!module) return;
      module.dataset.moduleState = "ready"; module.querySelector<HTMLElement>("[data-llm-ready]")!.hidden = false; module.querySelector<HTMLElement>("[data-llm-fallback]")!.hidden = true;
      const s = data.summary; const rate = s.successRate === null ? "N/A" : `${(s.successRate * 100).toFixed(2)}%`;
      const state = s.logicalRequests === 0 ? "No Data" : s.successRate >= .98 ? "Operational" : s.successRate >= .9 ? "Degraded" : s.successRate >= .5 ? "Partial Outage" : "Major Outage";
      module.querySelector<HTMLElement>("[data-llm-state]")!.textContent = state;
      setMetrics("[data-llm-summary]", [["Logical requests", String(s.logicalRequests)], ["Provider attempts", String(s.providerAttempts)], ["Total tokens", formatTokens(s.totalTokens)], ["Estimated cost", formatCost(s.estimatedCostUsd)], ["Success rate", rate], ["Average latency", formatLatency(s.averageLatencyMs)], ["Fallbacks", String(s.fallbackRequests)], ["Recovered", String(s.fallbackRecoveredRequests)]]);
      setMetrics("[data-llm-tokens]", [["Input", formatTokens(s.inputTokens)], ["Output", formatTokens(s.outputTokens)], ["Cached", formatTokens(s.cachedInputTokens)], ["Reasoning", formatTokens(s.reasoningTokens)], ["Estimated cost", formatCost(s.estimatedCostUsd)]]);
      setRows("[data-llm-trend]", data.trend.map((x: any) => `<span>${escapeHtml(new Date(x.bucket).toLocaleDateString(undefined, { month: "short", day: "numeric", hour: data.range === "24h" ? "numeric" : undefined }))}</span><strong>${escapeHtml(x.logical_requests)} / ${escapeHtml(x.attempts)}</strong>`));
      setRows("[data-llm-models]", data.models.map((x: any) => `<strong>${escapeHtml(x.provider)} / ${escapeHtml(x.model)}</strong><span>${escapeHtml(x.attempts)} attempts · ${escapeHtml(x.successes)}/${escapeHtml(x.attempts)} success · ${formatTokens(x.total_tokens)} · ${formatLatency(x.average_latency_ms)} · ${formatCost(x.estimated_cost_usd)}</span>`));
      setRows("[data-llm-sources]", data.sources.map((x: any) => `<strong>${escapeHtml(x.source)}</strong><span>${escapeHtml(x.attempts)} attempts · ${formatTokens(x.total_tokens)} · ${formatCost(x.estimated_cost_usd)}</span>`));
      setRows("[data-llm-fallbacks]", data.fallbacks.map((x: any) => `<strong>${escapeHtml(x.fallback_from_provider)}/${escapeHtml(x.fallback_from_model)} → ${escapeHtml(x.provider)}/${escapeHtml(x.model)}</strong><span>${escapeHtml(x.attempts)} attempts · ${escapeHtml(x.successes)} recovered · depth ${escapeHtml(x.fallback_depth)}</span>`));
      setRows("[data-llm-errors]", data.recentErrors.map((x: any) => `<strong>${escapeHtml(x.error_type ?? "unknown")}</strong><span>${escapeHtml(x.source)} · ${escapeHtml(x.provider)}/${escapeHtml(x.model)} · ${escapeHtml(new Date(x.created_at).toLocaleString())}</span>`));
    };
    const loadLLM = async (range = "24h") => {
      const module = document.querySelector<HTMLElement>("[data-status-module='llm']"); if (!module) return;
      try { const response = await fetch(`/api/status/llm?range=${encodeURIComponent(range)}`, { credentials: "same-origin" }); if (!response.ok) throw new Error(); renderLLM(await response.json()); }
      catch { module.dataset.moduleState = "error"; module.querySelector<HTMLElement>("[data-llm-state-title]")!.textContent = "LLM usage data temporarily unavailable"; module.querySelector<HTMLElement>("[data-llm-state-message]")!.textContent = "Sign in through Cloudflare Access to view private telemetry."; }
    };

    if (dashboard && scenario !== "normal") {
      const preview = await getStatusSnapshot(scenario);
      renderStatusSnapshot(dashboard, preview);
      updateSourceNotice(preview);
    } else if (dashboard && shouldLoadLiveStatus()) {
      await refreshDashboard(0);
    }
    if (dashboard) enhanceRelativeTimes(dashboard);
    void loadLLM();
    document.querySelectorAll<HTMLButtonElement>("[data-llm-range]").forEach((button) => button.addEventListener("click", () => { document.querySelectorAll<HTMLButtonElement>("[data-llm-range]").forEach((item) => item.setAttribute("aria-pressed", String(item === button))); void loadLLM(button.dataset.llmRange); }));

    refresh?.addEventListener("click", () => void refreshDashboard());
    const stopAutoRefresh = scheduleStatusRefresh(() => void refreshDashboard(0));

    window.addEventListener("pagehide", () => {
      controller.abort();
      stopAutoRefresh();
      statusMotion.revert();
    }, { once: true });
  </script>
</Layout>
