---
import Layout from "../../../layouts/Layout.astro";
import LocalLearningProgress from "../../../components/digital-starter/LocalLearningProgress.astro";
import {
  digitalStarterPublicStatusLabels,
  digitalStarterRouteModules,
  digitalStarterRoutes,
  digitalStarterSafetyNotes,
} from "../../../data/digitalStarter";
import "../../../styles/lab-status-shell.css";
import "../../../styles/lab.css";

const route = digitalStarterRoutes.find((item) => item.id === "computer");

if (!route) {
  throw new Error("Digital Starter computer route is missing.");
}

const modules = digitalStarterRouteModules.filter((module) => module.routeId === route.id);
---

<Layout
  title="电脑基础学习路线 | 准大学生数字技能启动包 | zxlab"
  description="用四个模块掌握文件管理、快捷键、软件工具和跨设备同步。"
  lang="zh-CN"
>
  <main class="digital-starter-detail-page digital-starter-computer-v2">
    <section class="digital-starter-detail-hero digital-starter-computer-hero" aria-labelledby="computer-route-title">
      <div class="digital-starter-detail-hero__copy">
        <a class="digital-starter-back" href="/lab/digital-starter">← 返回数字技能启动包</a>
        <p class="digital-starter-kicker">已开放的学习路线</p>
        <h1 id="computer-route-title">把电脑真正用顺手</h1>
        <p class="digital-starter-subtitle">{route.learningOutcome}</p>
        <p class="digital-starter-intro">按顺序完成四个短模块，大约一小时。你也可以只打开眼下最需要的一项。</p>
        <div class="digital-starter-computer-hero__meta">
          <span>{route.durationLabel}</span>
          <span>{digitalStarterPublicStatusLabels[route.publicStatus]}</span>
          <span>主要面向 Windows</span>
        </div>
        <div class="digital-starter-actions">
          <a class="digital-starter-button" href="#computer-modules">
            <span>开始第一个模块</span><span aria-hidden="true">↓</span>
          </a>
          <a class="digital-starter-button digital-starter-button--ghost" href="/lab/digital-starter/docs/tasks">
            <span>先做 10 分钟任务</span><span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
      <aside class="digital-starter-computer-hero__map" aria-label="路线概览" data-starter-image>
        <p>一小时学习路线</p>
        <ol>
          {modules.map((module, index) => (
            <li><span>{String(index + 1).padStart(2, "0")}</span><strong>{module.title}</strong><small>{module.duration}</small></li>
          ))}
        </ol>
      </aside>
    </section>

    <section class="digital-starter-computer-learning" id="computer-modules" aria-labelledby="computer-modules-title">
      <div class="digital-starter-section-heading">
        <p>四个模块</p>
        <h2 id="computer-modules-title">跟着顺序走，每一步都有明确结果。</h2>
      </div>

      <LocalLearningProgress
        storageKey="zxlab:digital-starter:computer:v1"
        itemIds={modules.map((module) => module.id)}
      />

      <div class="digital-starter-computer-timeline">
        {
          modules.map((module, index) => (
            <article class="digital-starter-computer-module" data-starter-reveal>
              <div class="digital-starter-computer-module__rail" aria-hidden="true">
                <span>{String(index + 1).padStart(2, "0")}</span>
              </div>
              <div class="digital-starter-computer-module__content">
                <div class="digital-starter-computer-module__heading">
                  <div>
                    <p>模块 {String(index + 1).padStart(2, "0")}</p>
                    <h3>{module.title}</h3>
                  </div>
                  <span data-progress-status-for={module.id} data-progress-state="idle">未开始</span>
                </div>
                <p class="digital-starter-computer-module__outcome">{module.outcome}</p>
                <dl>
                  <div>
                    <dt>核心文档</dt>
                    <dd><a href={module.coreDocument.href}>{module.coreDocument.title}</a></dd>
                  </div>
                  <div>
                    <dt>实战任务</dt>
                    <dd>
                      {module.practice.href ? <a href={module.practice.href}>{module.practice.title}</a> : module.practice.title}
                    </dd>
                  </div>
                  <div>
                    <dt>可选扩展</dt>
                    <dd>
                      {module.extension ? <a href={module.extension.href}>{module.extension.title}</a> : "完成核心文档后再继续"}
                    </dd>
                  </div>
                  <div>
                    <dt>预计用时</dt>
                    <dd>{module.duration}</dd>
                  </div>
                </dl>
                <div class="digital-starter-computer-module__actions">
                  <a href={module.coreDocument.href}>开始模块<span aria-hidden="true">↗</span></a>
                  <button type="button" data-progress-complete={module.id}>标记完成</button>
                  <button type="button" data-progress-cancel={module.id} hidden>取消完成</button>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="digital-starter-safety-note" aria-labelledby="computer-safety-title">
      <div>
        <p>先养成安全习惯</p>
        <h2 id="computer-safety-title">遇到不确定的操作，先停一下再确认。</h2>
      </div>
      <ul>
        {digitalStarterSafetyNotes.map((note) => <li>{note}</li>)}
      </ul>
    </section>
  </main>

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);
    const detailMotion = gsap.matchMedia();

    detailMotion.add("(prefers-reduced-motion: no-preference)", () => {
      gsap.from(".digital-starter-detail-hero__copy > *", {
        y: 34,
        opacity: 0,
        duration: 0.8,
        stagger: 0.07,
        ease: "power3.out",
      });

      gsap.from(".digital-starter-computer-hero__map", {
        scale: 0.86,
        opacity: 0,
        duration: 1,
        ease: "power3.out",
      });

      gsap.utils.toArray<HTMLElement>("[data-starter-reveal]").forEach((item) => {
        gsap.from(item, {
          y: 30,
          opacity: 0,
          duration: 0.72,
          ease: "power3.out",
          scrollTrigger: { trigger: item, start: "top 88%" },
        });
      });
    });
  </script>
</Layout>
