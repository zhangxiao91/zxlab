---
import Layout from "../../layouts/Layout.astro";
import {
  digitalStarterFeaturedResources,
  digitalStarterRoutes,
  digitalStarterStatusLabels,
  digitalStarterUpdates,
} from "../../data/digitalStarter";
import "../../styles/lab-status-shell.css";
import "../../styles/lab.css";

const starterTaskHref = "/lab/digital-starter/docs/tasks";
const starterTaskSteps = ["截取一张图片", "按规则重命名", "压缩为 ZIP 文件", "解压并确认内容"];
const taskRevealCopy = "先完成一次从截图到解压的完整操作，你就已经真正开始使用电脑了。";
---

<Layout
  title="准大学生数字技能启动包 | zxlab"
  description="进入大学前，用电脑、AI 和一点点编程完成几项真正有用的数字技能任务。"
  lang="zh-CN"
>
  <main class="digital-starter-page digital-starter-home-v2">
    <section class="digital-starter-hero digital-starter-home-hero" aria-labelledby="digital-starter-title">
      <div class="digital-starter-hero__copy">
        <a class="digital-starter-back" href="/lab">← 返回实验室</a>
        <p class="digital-starter-kicker">进入大学前，从这里开始</p>
        <h1 id="digital-starter-title">
          准大学生数字技能<span class="digital-starter-home-title-image" aria-hidden="true"></span>启动包
        </h1>
        <p class="digital-starter-subtitle">在进入大学前，把电脑、AI 和一点点编程真正用起来。</p>
        <p class="digital-starter-intro">无需注册，可以随时开始，主要面向 Windows 用户。</p>
        <div class="digital-starter-actions" aria-label="开始学习">
          <a class="digital-starter-button" href={starterTaskHref}>
            <span>开始第一项任务</span><span aria-hidden="true">↗</span>
          </a>
          <a class="digital-starter-button digital-starter-button--ghost" href="#learning-routes">
            <span>浏览学习路线</span><span aria-hidden="true">↓</span>
          </a>
        </div>
      </div>

      <aside class="digital-starter-home-hero__task" aria-label="第一项任务预览" data-starter-image>
        <div>
          <span>10 分钟</span>
          <strong>第一项任务</strong>
        </div>
        <h2>完成一次截图、命名、压缩与解压</h2>
        <ol>
          {starterTaskSteps.map((step, index) => <li><span>{index + 1}</span>{step}</li>)}
        </ol>
      </aside>
    </section>

    <section class="digital-starter-routes digital-starter-home-routes" id="learning-routes" aria-labelledby="routes-title">
      <div class="digital-starter-section-heading">
        <p>三条学习路线</p>
        <h2 id="routes-title">先选一个眼下最想解决的问题。</h2>
      </div>

      <div class="digital-starter-home-route-grid">
        {
          digitalStarterRoutes.map((route, index) => (
            <article class="digital-starter-home-route-card" data-starter-reveal>
              <div class="digital-starter-home-route-card__top">
                <span>{String(index + 1).padStart(2, "0")}</span>
                <span data-public-status={route.status}>
                  状态：{digitalStarterStatusLabels[route.status]}
                </span>
              </div>
              <h3>{route.title}</h3>
              <p>{route.learningOutcome}</p>
              <strong>{route.durationLabel}</strong>
              {route.detailHref ? (
                <a href={route.detailHref}>{route.actionLabel}<span aria-hidden="true">↗</span></a>
              ) : (
                <button type="button" disabled aria-describedby={`route-unavailable-${route.id}`}>
                  {route.actionLabel}
                </button>
              )}
              {!route.detailHref && (
                <small id={`route-unavailable-${route.id}`}>内容准备好后会在这里开放，不会跳转到空页面。</small>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <section class="digital-starter-first-task" aria-labelledby="first-task-title">
      <div class="digital-starter-first-task__copy">
        <p>从一个小任务开始</p>
        <h2 id="first-task-title">不知道从哪条路线开始？</h2>
        <p
          class="digital-starter-first-task__reveal"
          aria-label={taskRevealCopy}
          data-scrub-copy
        >
          {taskRevealCopy.split("").map((char) => <span aria-hidden="true">{char}</span>)}
        </p>
        <a class="digital-starter-button" href={starterTaskHref}>
          <span>开始 10 分钟任务</span><span aria-hidden="true">↗</span>
        </a>
      </div>
      <ol class="digital-starter-first-task__steps" aria-label="任务步骤摘要">
        {starterTaskSteps.map((step, index) => (
          <li data-task-stack>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{step}</strong>
          </li>
        ))}
      </ol>
    </section>

    <section class="digital-starter-featured" id="featured-resources" aria-labelledby="featured-title">
      <div class="digital-starter-section-heading digital-starter-section-heading--light">
        <p>精选资源</p>
        <h2 id="featured-title">只放现在值得打开的内容。</h2>
      </div>
      <div class="digital-starter-featured-grid">
        {
          digitalStarterFeaturedResources.map((resource) => (
            <article class="digital-starter-featured-card" data-starter-reveal>
              <div>
                <span>{resource.typeLabel}</span>
                <span data-public-status={resource.status}>
                  {digitalStarterStatusLabels[resource.status]}
                </span>
              </div>
              <h3>{resource.title}</h3>
              <p>{resource.description}</p>
              <small>{resource.duration}</small>
              {resource.href ? (
                <a href={resource.href}>{resource.actionLabel}<span aria-hidden="true">↗</span></a>
              ) : (
                <button type="button" disabled>{resource.actionLabel}</button>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <section class="digital-starter-training" aria-labelledby="training-title">
      <div>
        <p>用于课堂或分享会</p>
        <h2 id="training-title">digital-starter 也可以作为数字技能培训的配套内容使用。</h2>
      </div>
      <div class="digital-starter-training__actions" aria-label="培训功能">
        <button type="button" disabled>查看课程安排<span>即将开放</span></button>
        <button type="button" disabled>打开授课模式<span>即将开放</span></button>
      </div>
    </section>

    <section class="digital-starter-about">
      <details>
        <summary>关于本项目</summary>
        <div>
          <p>
            这是 zxlab 为准大学生整理的轻量数字技能学习项目。内容会优先补齐真实任务与可直接使用的文档，再逐步扩展 AI 和编程路线。
          </p>
          <p>
            页面内容由统一的数据结构维护，后续可以继续接入课程安排、授课模式、示例文件和培训资料。当前更新记录仅供了解项目进度。
          </p>
          <ol>
            {digitalStarterUpdates.map((update) => <li><time>{update.date}</time><span>{update.title}</span></li>)}
          </ol>
        </div>
      </details>
    </section>
  </main>

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const starterMotion = gsap.matchMedia();

    starterMotion.add("(prefers-reduced-motion: no-preference)", () => {
      gsap.from(".digital-starter-hero__copy > *", {
        y: 36,
        opacity: 0,
        duration: 0.82,
        stagger: 0.07,
        ease: "power3.out",
      });

      gsap.from(".digital-starter-home-hero__task", {
        scale: 0.86,
        opacity: 0,
        duration: 1.1,
        ease: "power3.out",
      });

      gsap.utils.toArray<HTMLElement>("[data-starter-reveal]").forEach((item) => {
        gsap.from(item, {
          y: 28,
          opacity: 0,
          duration: 0.72,
          ease: "power3.out",
          scrollTrigger: { trigger: item, start: "top 88%" },
        });
      });

      gsap.to("[data-scrub-copy] span", {
        opacity: 1,
        stagger: 0.025,
        ease: "none",
        scrollTrigger: {
          trigger: ".digital-starter-first-task",
          start: "top 76%",
          end: "center 56%",
          scrub: 0.8,
        },
      });

      gsap.utils.toArray<HTMLElement>("[data-task-stack]").forEach((card, index) => {
        gsap.from(card, {
          y: 72 + index * 18,
          rotate: index % 2 === 0 ? -1.5 : 1.5,
          scrollTrigger: {
            trigger: ".digital-starter-first-task__steps",
            start: "top 82%",
            end: "bottom 62%",
            scrub: 0.7,
          },
        });
      });
    });
  </script>
</Layout>
