---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="About | zxlab"
	description="About zhangxiao and the ideas behind zxlab."
>
	<main class="site-main">
		<section class="page-hero" aria-labelledby="about-title">
			<p class="eyebrow">ABOUT / ZXLAB</p>

			<h1 id="about-title">A student building things to understand them.</h1>

			<p class="intro">
				I am zhangxiao, a computer science student at Beihang University.
				ZXLab is where I document projects, technical experiments, and
				what I am currently learning.
			</p>
		</section>

		<section class="about-section" aria-labelledby="currently-title">
			<h2 id="currently-title">Currently</h2>

			<p>
				I am exploring AI evaluation, infrastructure, algorithms, and
				the practical craft of building reliable software.
			</p>
		</section>

		<section class="about-section" aria-labelledby="principles-title">
			<h2 id="principles-title">Principles</h2>

			<ul>
				<li>Build enough by hand to understand the system.</li>
				<li>Use tools to extend judgment, not replace it.</li>
				<li>Prefer real work and clear writing over decoration.</li>
			</ul>
		</section>
	</main>
</Layout>